# Copy this file to wrangler.toml.
# Replace OWNER with your GitHub user.
# Replace pattern with the real short domain.
# This project uses no secrets, but do not commit wrangler.toml if you add sensitive data.

name = "leanin"
main = "worker.js"
compatibility_date = "2026-06-14"

[vars]
OWNER = "SEU_USER_GITHUB"
REPO = "leanin"
BRANCH = "main"

[[routes]]
pattern = "SEU_DOMINIO_CURTO"
custom_domain = true
