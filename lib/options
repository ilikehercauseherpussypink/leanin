#!/usr/bin/env bash

declare -ag LEANIN_OPTION_FLAGS=(
    --dry-run
    --verbose
    --plan
    --doctor
    --version
    --yes
    --no-packages
    --no-pacman
    --no-flatpak
    --no-aur
    --no-services
    --no-codex
    --no-git
    --no-ssh
    --no-github
    --help
)
declare -Ag LEANIN_OPTION_HELP=(
    [--dry-run]='mostra ações sem alterar o sistema'
    [--verbose]='mostra comandos e saída completa'
    [--plan]='mostra somente o plano resumido'
    [--doctor]='verifica o ambiente sem alterar o sistema'
    [--version]='mostra a versão instalada'
    [--yes]='usa defaults seguros sem prompts'
    [--no-packages]='pula pacman, Flatpak e AUR'
    [--no-pacman]='pula pacotes pacman'
    [--no-flatpak]='pula Flatpak, Flathub e seus apps'
    [--no-aur]='pula AUR helper e pacotes AUR'
    [--no-services]='pula serviços system e user'
    [--no-codex]='pula Codex CLI'
    [--no-git]='pula identidade e preferências Git'
    [--no-ssh]='pula SSH local e integração GitHub SSH'
    [--no-github]='pula integração e autenticação GitHub'
    [--help]='mostra esta ajuda'
)

# Option globals are initialized here and read by control/feature modules after sourcing.
VERBOSE=0
DRY_RUN=0
PLAN_ONLY=0
DOCTOR_ONLY=0
ASSUME_YES=0
# Sourced global read by lib/control after option parsing.
# shellcheck disable=SC2034
CI_MODE=${LEANIN_CI:-${ARCHBOOT_CI:-0}}
SKIP_PACMAN=0
SKIP_FLATPAK=0
SKIP_AUR=0
SKIP_SERVICES=0
SKIP_CODEX=0
SKIP_GIT=0
SKIP_SSH=0
SKIP_GITHUB=0
declare -ag DISABLED_FEATURES=()

usage() {
    local flag

    printf 'Uso: bash install.sh [opções]\n\n'
    for flag in "${LEANIN_OPTION_FLAGS[@]}"; do
        printf '  %-14s %s\n' "$flag" "${LEANIN_OPTION_HELP[$flag]}"
    done
}

leanin_option_known() {
    local option=$1 flag
    [[ $option == -h ]] && return 0
    for flag in "${LEANIN_OPTION_FLAGS[@]}"; do
        [[ $option == "$flag" ]] && return 0
    done
    return 1
}

leanin_apply_option() {
    case $1 in
        --verbose)
            # Sourced option global read by lib/control and feature modules after parsing.
            # shellcheck disable=SC2034
            VERBOSE=1
            ;;
        --dry-run)
            # Sourced option global read by lib/control and feature modules after parsing.
            # shellcheck disable=SC2034
            DRY_RUN=1
            ;;
        --plan)
            # Sourced option global read by lib/control after parsing.
            # shellcheck disable=SC2034
            PLAN_ONLY=1
            ;;
        --doctor)
            # Sourced option global read by lib/control and prompt helpers after parsing.
            # shellcheck disable=SC2034
            DOCTOR_ONLY=1
            ;;
        --yes)
            # Sourced option global read by prompt and feature modules after parsing.
            # shellcheck disable=SC2034
            ASSUME_YES=1
            ;;
        --no-packages)
            SKIP_PACMAN=1
            SKIP_FLATPAK=1
            SKIP_AUR=1
            ;;
        --no-pacman) SKIP_PACMAN=1 ;;
        --no-flatpak) SKIP_FLATPAK=1 ;;
        --no-aur) SKIP_AUR=1 ;;
        --no-services) SKIP_SERVICES=1 ;;
        --no-codex) SKIP_CODEX=1 ;;
        --no-git) SKIP_GIT=1 ;;
        --no-ssh)
            SKIP_SSH=1
            SKIP_GITHUB=1
            ;;
        --no-github) SKIP_GITHUB=1 ;;
        --version) ;;
        --help|-h) usage; exit 0 ;;
        *) return 1 ;;
    esac
}

parse_args() {
    while (($#)); do
        if ! leanin_option_known "$1"; then
            die "opção desconhecida: $1"
        fi
        leanin_apply_option "$1"
        shift
    done
}

collect_disabled_features() {
    DISABLED_FEATURES=()
    (( SKIP_PACMAN )) && DISABLED_FEATURES+=('pacman')
    (( SKIP_FLATPAK )) && DISABLED_FEATURES+=('Flatpak')
    (( SKIP_AUR )) && DISABLED_FEATURES+=('AUR')
    (( SKIP_SERVICES )) && DISABLED_FEATURES+=('serviços')
    (( SKIP_CODEX )) && DISABLED_FEATURES+=('Codex')
    (( SKIP_GIT )) && DISABLED_FEATURES+=('Git')
    (( SKIP_SSH )) && DISABLED_FEATURES+=('SSH')
    (( SKIP_GITHUB )) && DISABLED_FEATURES+=('GitHub')
    return 0
}
