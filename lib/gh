#!/usr/bin/env bash

# GitHub SSH keys are managed through user/keys, the authentication-key API.
# This intentionally avoids gh ssh-key list, which may query signing keys too.
# GH_TOKEN/GITHUB_TOKEN are honored by gh and therefore need no interactive login.

GITHUB_KEYS_URL=${GITHUB_KEYS_URL:-'https://github.com/settings/keys'}
GITHUB_KEY_TITLE=''
GITHUB_NEW_KEY_STATUS='não configurada'
GITHUB_OLD_KEYS_STATUS='não verificadas'
GITHUB_SSH_MANAGEMENT_STATUS='não verificada'
GH_STATE='gh_unknown'
declare -ag GITHUB_KEY_IDS=() GITHUB_KEY_TITLES=() GITHUB_KEY_VALUES=()
declare -ag GITHUB_OLD_KEY_IDS=() GITHUB_OLD_KEY_TITLES=() GITHUB_OLD_KEY_VALUES=()

_github_decode() {
    local value=${1:-}
    [[ -n $value ]] && printf '%s' "$value" | base64 --decode 2>/dev/null
}

_github_key_material() {
    local key=${1:-} type='' material=''
    read -r type material _ <<<"$key" || true
    [[ -n $type && -n $material ]] || return 1
    printf '%s %s' "$type" "$material"
}

_github_tty_path() { printf '%s' /dev/tty; }

_github_tty_available() {
    local tty='' fd
    tty=$(_github_tty_path)
    [[ -n $tty && -e $tty ]] || return 1
    if ! { exec {fd}<>"$tty"; } 2>/dev/null; then
        return 1
    fi
    exec {fd}>&-
}

_github_auth_allowed() {
    (( ! ${ASSUME_YES:-0} && ! ${DRY_RUN:-0} && ${CI_MODE:-0} != 1 \
        && ! ${PLAN_ONLY:-0} && ! ${DOCTOR_ONLY:-0} )) \
        && _github_tty_available
}

github_detect_state() {
    if ! command_exists gh; then
        GH_STATE='gh_missing'
        GITHUB_SSH_MANAGEMENT_STATUS='indisponível'
    elif ! gh auth status >/dev/null 2>&1; then
        GH_STATE='gh_unauthenticated'
        GITHUB_SSH_MANAGEMENT_STATUS='pendente'
    elif gh api --silent user/keys >/dev/null 2>&1; then
        GH_STATE='gh_key_api_available'
        GITHUB_SSH_MANAGEMENT_STATUS='disponível'
    else
        GH_STATE='gh_authenticated_no_public_key_scope'
        GITHUB_SSH_MANAGEMENT_STATUS='indisponível'
    fi
    printf '%s' "$GH_STATE"
}

github_key_api_available() {
    github_detect_state >/dev/null
    [[ $GH_STATE == gh_key_api_available ]]
}

_github_auth_command() {
    local mode=$1
    case $mode in
        login) printf '%s\0' gh auth login -h github.com -p ssh -s admin:public_key --web ;;
        refresh) printf '%s\0' gh auth refresh -h github.com -s admin:public_key ;;
        *) return 2 ;;
    esac
}

github_run_auth() {
    local mode=$1 tty='' fd status=0 description=''
    local -a command=()
    mapfile -d '' -t command < <(_github_auth_command "$mode") || return 2
    tty=$(_github_tty_path)
    if [[ -z $tty || ! -e $tty ]] || ! { exec {fd}<>"$tty"; } 2>/dev/null; then
        return 1
    fi

    case $mode in
        login) description='autenticação GitHub' ;;
        refresh) description='atualização de permissões GitHub' ;;
    esac
    info "$description será executada neste terminal"
    info "comando: $(_render_command "${command[@]}")"
    info 'o GitHub pode mostrar um código único para copiar'
    info 'autentique no navegador, retorne a este terminal e pressione Enter se solicitado'
    _log_command "${command[@]}"
    set +e
    # gh owns this interactive exchange. A timeout here would make a human flow less reliable.
    "${command[@]}" <&"$fd" >&"$fd" 2>&"$fd"
    status=$?
    exec {fd}>&-
    set -e
    if (( status != 0 )); then
        warn "$description não foi concluída"
        return "$status"
    fi
    info 'GitHub CLI retornou; verificando autenticação e permissões SSH'
    return 0
}

github_prepare_key_api() {
    local mode=''
    github_detect_state >/dev/null
    case $GH_STATE in
        gh_key_api_available) return 0 ;;
        gh_missing)
            warn 'GitHub CLI não está disponível'
            info 'instale github-cli e execute leanin novamente'
            return 1
            ;;
        gh_unauthenticated)
            mode=login
            ;;
        gh_authenticated_no_public_key_scope)
            mode=refresh
            ;;
        *) return 1 ;;
    esac

    if (( DRY_RUN )); then
        printf '> [dry-run] executaria %s com admin:public_key\n' \
            "$([[ $mode == login ]] && printf 'autenticação GitHub' || printf 'atualização de permissões GitHub')"
        return 1
    fi
    if ! _github_auth_allowed; then
        if [[ $mode == login ]]; then
            info 'login: gh auth login -h github.com -p ssh -s admin:public_key --web'
        else
            info 'corrija: gh auth refresh -h github.com -s admin:public_key'
        fi
        return 1
    fi
    if [[ $mode == login ]]; then
        if ! yesno 'Autenticar GitHub CLI agora?' n; then
            skip 'autenticação GitHub CLI recusada'
            return 1
        fi
    elif ! yesno 'Atualizar permissões GitHub CLI agora?' n; then
        skip 'atualização de permissões GitHub recusada'
        return 1
    fi
    github_run_auth "$mode" || return 1
    github_key_api_available
}

github_list_ssh_keys() {
    local output='' id='' encoded_title='' encoded_key='' extra='' title='' key='' index
    GITHUB_KEY_IDS=()
    GITHUB_KEY_TITLES=()
    GITHUB_KEY_VALUES=()
    if ! run_capture output 'listar chaves SSH de autenticação do GitHub' \
        gh api --paginate user/keys \
        --jq '.[] | [.id, (.title | @base64), (.key | @base64)] | @tsv'; then
        warn 'não foi possível listar chaves SSH de autenticação do GitHub'
        return 1
    fi
    while IFS=$'\t' read -r id encoded_title encoded_key extra; do
        [[ -n $id && -n $encoded_title && -n $encoded_key && -z $extra ]] || continue
        title=$(_github_decode "$encoded_title") || continue
        key=$(_github_decode "$encoded_key") || continue
        GITHUB_KEY_IDS+=("$id")
        GITHUB_KEY_TITLES+=("$title")
        GITHUB_KEY_VALUES+=("$key")
    done <<<"$output"
    for index in "${!GITHUB_KEY_IDS[@]}"; do
        printf 'GitHub authentication key: %s %s\n' \
            "${GITHUB_KEY_IDS[$index]}" "${GITHUB_KEY_TITLES[$index]}" >>"$LOG_FILE"
    done
    return 0
}

github_key_exists() {
    local public_key=${1:-} expected='' key='' material=''
    [[ -r $public_key ]] || return 1
    expected=$(_github_key_material "$(<"$public_key")") || return 1
    for key in "${GITHUB_KEY_VALUES[@]}"; do
        material=$(_github_key_material "$key") || continue
        [[ $material == "$expected" ]] && return 0
    done
    return 1
}

_github_default_title() {
    local host=''
    host=$(hostname -s 2>/dev/null || hostname 2>/dev/null || printf 'host')
    host=${host//[^A-Za-z0-9._-]/-}
    printf 'leanin-%s-%s' "${USER:-user}" "$host"
}

github_add_ssh_key() {
    local public_key=$1 title=$2 key=''
    [[ -r $public_key ]] || return 1
    key=$(<"$public_key")
    if run_cmd 'cadastrar chave SSH de autenticação no GitHub' \
        gh api -X POST user/keys -f "title=$title" -f "key=$key"; then
        if github_list_ssh_keys && github_key_exists "$public_key"; then
            GITHUB_NEW_KEY_STATUS='cadastrada automaticamente'
            ok "chave GitHub cadastrada: $title"
            return 0
        fi
        warn 'GitHub aceitou o cadastro, mas a chave não foi confirmada'
    fi
    GITHUB_NEW_KEY_STATUS='falhou'
    return 1
}

github_collect_old_ssh_keys() {
    local public_key=$1 expected='' key='' material='' index
    GITHUB_OLD_KEY_IDS=()
    GITHUB_OLD_KEY_TITLES=()
    GITHUB_OLD_KEY_VALUES=()
    expected=$(_github_key_material "$(<"$public_key")") || return 1
    for index in "${!GITHUB_KEY_IDS[@]}"; do
        key=${GITHUB_KEY_VALUES[$index]}
        material=$(_github_key_material "$key") || continue
        [[ $material == "$expected" ]] && continue
        GITHUB_OLD_KEY_IDS+=("${GITHUB_KEY_IDS[$index]}")
        GITHUB_OLD_KEY_TITLES+=("${GITHUB_KEY_TITLES[$index]}")
        GITHUB_OLD_KEY_VALUES+=("$key")
    done
}

github_delete_ssh_keys() {
    local index id failed=0 count=${#GITHUB_OLD_KEY_IDS[@]}
    (( count > 0 )) || { GITHUB_OLD_KEYS_STATUS='mantidas'; return 0; }
    info "$count chaves SSH antigas encontradas no GitHub"
    if ! yesno 'remover chaves SSH antigas do GitHub que não são a chave atual?' n; then
        GITHUB_OLD_KEYS_STATUS='mantidas'
        skip 'chaves SSH antigas mantidas'
        return 0
    fi
    for index in "${!GITHUB_OLD_KEY_IDS[@]}"; do
        id=${GITHUB_OLD_KEY_IDS[$index]}
        if ! run_cmd "remover chave SSH antiga do GitHub: $id" \
            gh api -X DELETE "user/keys/$id"; then
            failed=1
        fi
    done
    if (( failed )); then
        GITHUB_OLD_KEYS_STATUS='falhou'
        warn 'uma ou mais chaves SSH antigas não foram removidas'
    else
        GITHUB_OLD_KEYS_STATUS='removidas'
        ok 'chaves SSH antigas removidas'
    fi
}

github_manual_ssh_key() {
    case $GH_STATE in
        gh_unauthenticated) GITHUB_NEW_KEY_STATUS='autenticação pendente' ;;
        gh_authenticated_no_public_key_scope) GITHUB_NEW_KEY_STATUS='permissão SSH pendente' ;;
        *) GITHUB_NEW_KEY_STATUS='cadastro manual pendente' ;;
    esac
    warn 'integração automática GitHub SSH não foi concluída'
    print_pubkey || true
    case $GH_STATE in
        gh_unauthenticated) info 'login: gh auth login -h github.com -p ssh -s admin:public_key --web' ;;
        gh_authenticated_no_public_key_scope) info 'corrija: gh auth refresh -h github.com -s admin:public_key' ;;
    esac
    info "adicione a chave em: $GITHUB_KEYS_URL"
    info 'depois execute: ssh -T git@github.com'
}

github_manage_ssh_key() {
    local public_key=${1:-} title=''
    [[ -r $public_key ]] || { GITHUB_NEW_KEY_STATUS='chave local indisponível'; return 1; }
    if (( DRY_RUN )); then
        printf '> [dry-run] consultaria a API user/keys do GitHub\n'
        printf '> [dry-run] autenticaria ou atualizaria admin:public_key se necessário\n'
        printf '> [dry-run] perguntaria se deve cadastrar a chave SSH\n'
        GITHUB_NEW_KEY_STATUS='dry-run'
        return 0
    fi
    if ! github_prepare_key_api; then
        github_manual_ssh_key
        return 0
    fi
    if ! github_list_ssh_keys; then
        github_manual_ssh_key
        return 0
    fi
    if github_key_exists "$public_key"; then
        GITHUB_NEW_KEY_STATUS='já cadastrada'
        skip 'chave GitHub já cadastrada'
    else
        if ! yesno 'Cadastrar esta chave SSH no GitHub?' n; then
            GITHUB_NEW_KEY_STATUS='cadastro manual pendente'
            skip 'cadastro da chave GitHub recusado'
            github_manual_ssh_key
            return 0
        fi
        title=$(_github_default_title)
        prompt title 'título da chave no GitHub' "$title"
        title=${title:-$(_github_default_title)}
        GITHUB_KEY_TITLE=$title
        github_add_ssh_key "$public_key" "$title" || { github_manual_ssh_key; return 0; }
    fi
    if github_collect_old_ssh_keys "$public_key"; then
        github_delete_ssh_keys
    fi
}

github_ssh_registration_ready() {
    case ${GITHUB_NEW_KEY_STATUS:-} in
        'já cadastrada'|'cadastrada automaticamente') return 0 ;;
    esac
    return 1
}

github_summary_state() {
    case ${GITHUB_NEW_KEY_STATUS:-} in
        'já cadastrada') printf '%s' 'já cadastrada' ;;
        'cadastrada automaticamente') printf '%s' 'cadastrada automaticamente' ;;
        'autenticação pendente') printf '%s' 'autenticação pendente' ;;
        'permissão SSH pendente') printf '%s' 'permissão SSH pendente' ;;
        'cadastro manual pendente') printf '%s' 'cadastro manual pendente' ;;
        dry-run) printf '%s' 'planejada (dry-run)' ;;
        'chave local indisponível') printf '%s' 'chave local indisponível' ;;
        falhou) printf '%s' 'falhou' ;;
        *) printf '%s' 'não configurada' ;;
    esac
}
