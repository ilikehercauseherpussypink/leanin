service_mock() {
    local mode=$1
    local marker="$ssh_test_home/service-$mode"
    rm -f "$marker"
    HOME="$ssh_test_home" MODE="$mode" MARKER="$marker" bash -c '
        set -Eeuo pipefail
        source lib/log
        source lib/ask
        source lib/service
        VERBOSE=0
        DRY_RUN=0
        [[ $MODE == dry ]] && DRY_RUN=1
        LOG_FILE=/dev/null
        FAILURES=()
        systemctl() {
            case ${1:-} in
                cat)
                    [[ $MODE != missing ]]
                    ;;
                is-enabled|is-active)
                    [[ $MODE == active ]]
                    ;;
                *)
                    return 1
                    ;;
            esac
        }
        run_sudo() {
            shift
            printf "%s\n" "$*" >>"$MARKER"
        }
        run_cmd() {
            shift
            printf "%s\n" "$*" >>"$MARKER"
        }
        ask_reconfigure() {
            case $MODE in
                inactive-yes) return 0 ;;
                *) return 1 ;;
            esac
        }
        service_enable system mullvad-daemon.service
        case $MODE in
            inactive-yes)
                ((${#SERVICES_ACTIVATED[@]} == 1))
                grep -Fqx "systemctl enable --now mullvad-daemon.service" "$MARKER"
                ;;
            inactive-no|dry)
                ((${#SERVICES_SKIPPED[@]} == 1))
                [[ ! -e $MARKER ]]
                ;;
            missing)
                ((${#SERVICES_SKIPPED[@]} == 1))
                [[ ! -e $MARKER ]]
                ;;
            active)
                ((${#SERVICES_ALREADY[@]} == 1))
                [[ ! -e $MARKER ]]
                ;;
        esac
        ((${#FAILURES[@]} == 0))
    '
}

if service_mock inactive-yes >/dev/null 2>&1 \
    && service_mock inactive-no >/dev/null 2>&1 \
    && service_mock missing >/dev/null 2>&1 \
    && service_mock active >/dev/null 2>&1 \
    && service_mock dry >/dev/null 2>&1; then
    ok 'serviços inativos pedem confirmação; ativos e ausentes são pulados'
else
    error 'mock modular de serviços falhou'
    ((failures += 1))
fi

