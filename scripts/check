        elif [[ $1 == remotes && $2 == --show-details ]]; then
            printf "flathub\tFlathub\thttps://example.invalid/repo/\n"
        else
            exit 90
        fi
    }
    run_cmd() { exit 90; }
    flatpak_remote
' 2>&1) \
    && grep -Fq '[dry-run] perguntaria se deve refazer flathub já existe com configuração diferente' <<<"$flatpak_divergent_output" \
    && ! grep -Fq 'remote-modify' <<<"$flatpak_divergent_output"; then
    ok 'Flathub divergente pede confirmação e dry-run não o modifica'
