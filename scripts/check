#!/usr/bin/env bash
touch "$gh_marker"
exit 99
EOF
chmod +x "$fake_bin/gh"
if github_dry_output=$(HOME="$ssh_test_home" PATH="$fake_bin:$PATH" bash -c '
    source lib/log
    source lib/ask
    source lib/env
    source lib/run
    source lib/open
    source lib/gh
