if flatpak_divergent_output=$(bash -c '
    set -Eeuo pipefail
    source lib/log
    source lib/ask
    source lib/flatpak
    DRY_RUN=1
    LOG_FILE=/dev/null
    FAILURES=()
    flatpak() {
