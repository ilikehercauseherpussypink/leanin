    FAILURES=()
    AUR_INSTALLED=()
    AUR_SKIPPED=()
    AUR_PLANNED=()
    AUR_ALREADY=()
    pacman() {
        [[ ${1:-} == -Qq && ${2:-} == mullvad-vpn-daemon ]]
    }
    run_cmd() {
        exit 90
    }
    install mullvad-vpn-bin
    ((${#FAILURES[@]} == 0))
    ((${#AUR_SKIPPED[@]} == 1))
    [[ ${AUR_SKIPPED[0]} == mullvad-vpn-bin ]]
' >/dev/null 2>&1; then
    ok 'Mullvad existente bloqueia variante conflitante sem falha'
else
    error 'proteção contra conflito Mullvad falhou'
    ((failures += 1))
fi

