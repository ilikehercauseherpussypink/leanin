#!/usr/bin/env bash
set -Eeuo pipefail

ROOT=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)
cd "$ROOT"

ok()    { printf '> [ok] %s\n' "$*"; }
skip()  { printf '> [skip] %s\n' "$*"; }
error() { printf '> [error] %s\n' "$*" >&2; }
step()  { printf '\n> Etapa %s/%s: %s\n' "$1" "$2" "$3"; }

failures=0

check_file() {
    if [[ ! -f $1 ]]; then
        error "arquivo ausente: $1"
        ((failures += 1))
    elif [[ ! -s $1 ]]; then
        error "arquivo obrigatório vazio: $1"
        ((failures += 1))
    else
        ok "$1"
    fi
}

app_lines() {
    local file=$1 line
    while IFS= read -r line || [[ -n $line ]]; do
        line=${line#"${line%%[![:space:]]*}"}
        [[ -z $line || $line == \#* ]] && continue
        line=${line%%[[:space:]]#*}
        line=${line%"${line##*[![:space:]]}"}
        [[ -n $line ]] && printf '%s\n' "$line"
    done <"$file"
}

step 1 10 'validando estrutura'
required=(
    install.sh README.md CHANGELOG.md LICENSE .gitignore
    docs/TROUBLESHOOTING.md docs/APPS.md docs/SAFETY.md docs/assets/leanin.svg
    .github/workflows/check.yml
    scripts/check scripts/github
    cloudflare/worker.js cloudflare/wrangler.toml.example cloudflare/README.md
    lib/log lib/ask lib/env lib/doctor lib/run lib/pkg lib/flatpak lib/aur lib/apps lib/service
    lib/git lib/ssh lib/gh lib/codex lib/open
    apps/pacman/base apps/pacman/dev apps/pacman/browsers apps/pacman/audio
    apps/pacman/privacy apps/pacman/system
    apps/flatpak/chat apps/flatpak/media apps/flatpak/mail
    apps/flatpak/privacy apps/flatpak/tools apps/flatpak/games
    apps/aur/browsers apps/aur/privacy apps/aur/media apps/aur/tools
    services/system services/user
)
for file in "${required[@]}"; do
    check_file "$file"
done
for file in install.sh scripts/check scripts/github; do
    if [[ -x $file ]] && head -n 1 "$file" | grep -Fqx '#!/usr/bin/env bash'; then
        ok "$file é executável com shebang Bash"
    else
        error "$file precisa ser executável com shebang Bash"
        ((failures += 1))
    fi
done

step 2 10 'validando sintaxe Bash'
mapfile -t bash_files < <(printf '%s\n' install.sh scripts/check scripts/github; find lib -maxdepth 1 -type f | sort)
for file in "${bash_files[@]}"; do
    if bash -n "$file"; then
        ok "bash -n $file"
    else
        error "sintaxe inválida: $file"
        ((failures += 1))
    fi
done

step 3 10 'validando listas de apps'
flatpak_pattern='^[A-Za-z0-9_-]+(\.[A-Za-z0-9_-]+){2,}$'
package_pattern='^[A-Za-z0-9@._+-]+$'
declare -A seen_apps=()
for file in apps/flatpak/*; do
    while IFS= read -r app; do
        if [[ $app == @openai/codex ]]; then
            error "$file contém @openai/codex"
            ((failures += 1))
        elif [[ ! $app =~ $flatpak_pattern ]]; then
            if ! grep -Fq "$app # leanin: allow-simple" "$file"; then
                error "$file contém ID Flatpak improvável: $app"
                ((failures += 1))
            fi
        elif [[ -n ${seen_apps["flatpak:$app"]:-} ]]; then
            error "$file duplica $app já listado em ${seen_apps["flatpak:$app"]}"
            ((failures += 1))
        else
            seen_apps["flatpak:$app"]=$file
        fi
    done < <(app_lines "$file")
done
for source in pacman aur; do
    for file in "apps/$source"/*; do
        while IFS= read -r app; do
            if [[ $app == @openai/codex ]]; then
                error "$file contém @openai/codex"
                ((failures += 1))
            elif [[ $app =~ $flatpak_pattern ]]; then
                error "$file parece conter ID Flatpak: $app"
                ((failures += 1))
            elif [[ ! $app =~ $package_pattern ]]; then
                error "$file contém pacote com formato inválido: $app"
                ((failures += 1))
            elif [[ -n ${seen_apps["$source:$app"]:-} ]]; then
                error "$file duplica $app já listado em ${seen_apps["$source:$app"]}"
                ((failures += 1))
            else
                seen_apps["$source:$app"]=$file
            fi
        done < <(app_lines "$file")
    done
done
if grep -Fxq 'org.vinegarhq.Sober' apps/flatpak/games \
    && ! grep -RFx 'org.vinegarhq.Sober' apps/pacman apps/aur >/dev/null 2>&1; then
    ok 'Sober está somente na categoria Flatpak games'
else
    error 'Sober precisa estar apenas em apps/flatpak/games'
    ((failures += 1))
fi
if bash -c '
    set -Eeuo pipefail
    source lib/log
    source lib/apps
    LEANIN_ROOT=$1
    LOG_FILE=/dev/null
    read_pacman
    [[ ${#PACMAN_APPS[@]} == 11 ]]
    read_flatpak
    read_aur
    read_pacman
    [[ ${#PACMAN_APPS[@]} == 11 ]]
    [[ ${#FLATPAK_APPS[@]} == 6 ]]
    [[ ${#AUR_APPS[@]} == 3 ]]
' _ "$ROOT" >/dev/null 2>&1; then
    ok 'leitura de apps é idempotente por fonte'
else
    error 'leitura repetida de apps duplicou ou perdeu entradas'
    ((failures += 1))
fi
if ! bash -c '
    set -Eeuo pipefail
    source lib/apps
    _app_item_valid pacman "bad;package"
' >/dev/null 2>&1 \
    && ! bash -c '
        set -Eeuo pipefail
        source lib/apps
        _app_item_valid aur "bad package"
    ' >/dev/null 2>&1 \
    && ! bash -c '
        set -Eeuo pipefail
        source lib/apps
        _app_item_valid flatpak "not-a-flatpak"
    ' >/dev/null 2>&1; then
    ok 'parser rejeita entradas de apps inseguras ou improváveis'
else
    error 'parser aceitou entrada de app inválida'
    ((failures += 1))
fi
for file in services/system services/user; do
    declare -A seen_services=()
    while IFS= read -r service; do
        if [[ ! $service =~ ^[A-Za-z0-9@_.:-]+\.service$ ]]; then
            error "$file contém serviço com formato inválido: $service"
            ((failures += 1))
        elif [[ -n ${seen_services["$service"]:-} ]]; then
            error "$file duplica serviço: $service"
            ((failures += 1))
        else
            seen_services["$service"]=1
        fi
    done < <(app_lines "$file")
done
(( failures == 0 )) && ok 'listas de apps válidas'
if grep -Fxq easyeffects apps/pacman/audio; then
    ok 'EasyEffects está na categoria pacman/audio'
else
    error 'EasyEffects ausente de apps/pacman/audio'
    ((failures += 1))
fi
if grep -Fxq mullvad-daemon.service services/system; then
    ok 'mullvad-daemon.service está em services/system'
else
    error 'mullvad-daemon.service ausente de services/system'
    ((failures += 1))
fi

step 4 10 'validando regras de segurança'
forbidden_step=$(printf '%s%s' '==' '>')
if grep -RFn --exclude-dir=.git -- "$forbidden_step" . >/dev/null 2>&1; then
    error "prefixo proibido encontrado: $forbidden_step"
    ((failures += 1))
else
    ok 'prefixo de etapas válido'
fi
if grep -En 'git[[:space:]]+(diff|status)' install.sh >/dev/null 2>&1; then
    error 'install.sh contém git diff ou git status'
    ((failures += 1))
else
    ok 'install.sh não imprime diff/status'
fi
# Os padrões abaixo verificam texto-fonte literal, sem expansão nesta execução.
# shellcheck disable=SC2016
if grep -Fq 'LEANIN_REPO=https://github.com/ilikehercauseherpussypink/leanin' install.sh \
    && grep -Fq 'LEANIN_BRANCH=main' install.sh \
    && grep -Fq 'CI_MODE=${LEANIN_CI:-${ARCHBOOT_CI:-0}}' install.sh; then
    ok 'bootstrap remoto aponta para o repositório publicado'
else
    error 'default LEANIN_REPO não aponta para ilikehercauseherpussypink/leanin'
    ((failures += 1))
fi
leanin_var_count=$(grep -Roh -- 'LEANIN_' install.sh lib | wc -l)
legacy_var_count=$(grep -Roh -- 'ARCHBOOT_' install.sh lib | wc -l)
if (( leanin_var_count > legacy_var_count )); then
    ok 'LEANIN_* é primário e ARCHBOOT_* permanece apenas como compatibilidade'
else
    error 'ARCHBOOT_* ainda domina as variáveis internas'
    ((failures += 1))
fi
# Os padrões abaixo verificam texto-fonte literal, sem expansão nesta execução.
# shellcheck disable=SC2016
if grep -Fq 'LEANIN_STATE_DIR="$state_home/leanin"' lib/env \
    && grep -Fq 'LEANIN_LOG_DIR="$LEANIN_STATE_DIR/logs"' lib/env; then
    ok 'estado e logs usam ~/.local/state/leanin'
else
    error 'estado ou logs não usam o caminho leanin'
    ((failures += 1))
fi
unsafe_eval=$(printf '%s%s' 'eval' '[[:space:]]')
if grep -REn "^[[:space:]]*$unsafe_eval" install.sh lib scripts cloudflare >/dev/null 2>&1; then
    error 'eval inseguro encontrado'
    ((failures += 1))
else
    ok 'nenhum eval inseguro encontrado'
fi

unsafe_cleanup=0
while IFS= read -r cleanup_line; do
    # Os padrões verificam texto-fonte literal, sem expansão nesta execução.
    # shellcheck disable=SC2016
    case $cleanup_line in
        *'rm -rf -- "$temp_dir"'*|*'rm -rf -- "$build_dir"'*) ;;
        *)
            error "remoção recursiva não reconhecida: $cleanup_line"
            unsafe_cleanup=1
            ;;
    esac
done < <(grep -REn 'rm[[:space:]]+-rf' install.sh lib scripts/github 2>/dev/null || true)
if (( unsafe_cleanup )); then
    ((failures += 1))
else
    ok 'remoções temporárias usam diretórios conhecidos e delimitador --'
fi
if grep -REn '(chmod|chown)[[:space:]]+(-[[:alnum:]]*R|--recursive)' \
    install.sh lib scripts/github >/dev/null 2>&1; then
    error 'chmod/chown recursivo encontrado'
    ((failures += 1))
else
    ok 'nenhum chmod/chown recursivo encontrado'
fi
if grep -Fq 'https://archlinux.org/ >/dev/null 2>&1' lib/env; then
    ok 'preflight de internet não vaza saída crua do curl'
else
    error 'preflight de internet pode vazar saída crua do curl'
    ((failures += 1))
fi
if grep -REn 'curl[^|]*\|[[:space:]]*(bash|sh)|wget[^|]*\|[[:space:]]*(bash|sh)' \
    install.sh lib scripts/github .github cloudflare/worker.js >/dev/null 2>&1; then
    error 'pipe remoto para shell encontrado no código executável'
    ((failures += 1))
else
    ok 'nenhum curl/wget pipe shell interno encontrado'
fi
if grep -REn 'git[[:space:]]+(push|tag)[^#]*--force|git[[:space:]]+tag[[:space:]]+-f' \
    install.sh lib scripts/github .github >/dev/null 2>&1; then
    error 'operação Git forçada encontrada'
    ((failures += 1))
else
    ok 'nenhum git push/tag forçado encontrado'
fi
if grep -REn '(rm|unlink)[^#]*/var/lib/pacman/db\.lck' \
    install.sh lib scripts/github >/dev/null 2>&1; then
    error 'remoção automática do lock do pacman encontrada'
    ((failures += 1))
else
    ok 'lock do pacman nunca é removido automaticamente'
fi

tracked_sensitive=''
if [[ -d .git ]]; then
    tracked_sensitive=$(git ls-files | grep -E \
        '(^|/)(\.env($|\.)|wrangler\.toml$|id_ed25519(\.pub)?$)|\.(key|pem|log)$|(^|/)(node_modules|\.cache|tmp)/' \
        || true)
fi
if [[ -n $tracked_sensitive ]]; then
    error 'arquivos sensíveis ou gerados estão versionados:'
    printf '%s\n' "$tracked_sensitive" >&2
    ((failures += 1))
else
    ok 'nenhum artefato sensível ou gerado está versionado'
fi

# Os tokens verificam texto-fonte literal, sem expansão nesta execução.
# shellcheck disable=SC2016
bootstrap_tokens=(
    'temp_dir=$(mktemp -d)'
    '[[ ! -s $archive ]]'
    'trap cleanup_bootstrap EXIT'
    'validate_bootstrap_repo "$LEANIN_REPO"'
    'validate_bootstrap_branch "$LEANIN_BRANCH"'
    'curl -fsSL --retry 3 --connect-timeout 10 --max-time 120'
    'tar -tzf "$archive"'
    'tar -xzf "$archive" --no-same-owner --no-same-permissions'
    'if ((${#roots[@]} != 1))'
    '((${#FAILURES[@]} == 0))'
)
for token in "${bootstrap_tokens[@]}"; do
    if ! grep -Fq "$token" install.sh; then
        error "bootstrap sem proteção esperada: $token"
        ((failures += 1))
    fi
done

ssh_test_home=$(mktemp -d)
trap 'rm -rf -- "$ssh_test_home"' EXIT
bootstrap_bin="$ssh_test_home/bootstrap-bin"
mkdir -p "$bootstrap_bin"
cat >"$bootstrap_bin/mktemp" <<'EOF'
#!/usr/bin/env bash
mkdir -p "$BOOTSTRAP_TEMP"
printf '%s\n' "$BOOTSTRAP_TEMP"
EOF
cat >"$bootstrap_bin/curl" <<'EOF'
#!/usr/bin/env bash
output=''
printf '%s\n' "$@" >"$CURL_ARGS_FILE"
while (($#)); do
    if [[ $1 == -o ]]; then
        output=$2
        shift 2
    else
        shift
    fi
done
[[ -n $output ]] || exit 2
case $BOOTSTRAP_MODE in
    curlfail) exit 22 ;;
    empty) : >"$output" ;;
    small) head -c 512 /dev/zero >"$output" ;;
    *) head -c 2048 /dev/zero >"$output" ;;
esac
EOF
cat >"$bootstrap_bin/tar" <<'EOF'
#!/usr/bin/env bash
destination=''
if [[ $1 == -tzf ]]; then
    case $BOOTSTRAP_MODE in
        incomplete)
            printf 'leanin-main/\nleanin-main/install.sh\n'
            ;;
        multiple)
            printf '%s\n' \
                'leanin-main/install.sh' 'leanin-main/lib/' 'leanin-main/apps/' 'leanin-main/services/' \
                'other/install.sh' 'other/lib/' 'other/apps/' 'other/services/'
            ;;
        traversal)
            printf '../outside/install.sh\n'
            ;;
        outside)
            printf '%s\n' 'leanin-main/install.sh' 'leanin-main/lib/' 'leanin-main/apps/' 'leanin-main/services/'
            ;;
        valid)
            printf '%s\n' 'leanin-main/install.sh' 'leanin-main/lib/' 'leanin-main/apps/' 'leanin-main/services/'
            ;;
        *) exit 2 ;;
    esac
    exit 0
fi
while (($#)); do
    if [[ $1 == -C ]]; then
        destination=$2
        shift 2
    else
        shift
    fi
done
[[ -n $destination ]] || exit 2
mkdir -p "$destination"
if [[ $BOOTSTRAP_MODE == outside ]]; then
    mkdir -p "$BOOTSTRAP_OUTSIDE"
    ln -s "$BOOTSTRAP_OUTSIDE" "$destination/leanin-main"
    exit 0
fi
mkdir -p "$destination/leanin-main"
printf '#!/usr/bin/env bash\nprintf "mock project loaded\\n"\n' \
    >"$destination/leanin-main/install.sh"
if [[ $BOOTSTRAP_MODE == valid ]]; then
    mkdir -p "$destination/leanin-main/lib" \
        "$destination/leanin-main/apps" "$destination/leanin-main/services"
fi
EOF
chmod +x "$bootstrap_bin/mktemp" "$bootstrap_bin/curl" "$bootstrap_bin/tar"

bootstrap_empty_dir="$ssh_test_home/bootstrap-empty"
if bootstrap_empty_output=$(BOOTSTRAP_TEMP="$bootstrap_empty_dir" BOOTSTRAP_MODE=empty \
    CURL_ARGS_FILE="$ssh_test_home/curl-empty.args" \
    PATH="$bootstrap_bin:$PATH" bash -s -- --plan <install.sh 2>&1); then
    error 'bootstrap aceitou tarball vazio'
    ((failures += 1))
elif grep -Fq 'tarball baixado está vazio' <<<"$bootstrap_empty_output" \
    && [[ ! -e $bootstrap_empty_dir ]]; then
    ok 'bootstrap rejeita tarball vazio e limpa temporário'
else
    error 'bootstrap vazio falhou sem mensagem ou limpeza esperada'
    ((failures += 1))
fi

bootstrap_small_dir="$ssh_test_home/bootstrap-small"
if bootstrap_small_output=$(BOOTSTRAP_TEMP="$bootstrap_small_dir" BOOTSTRAP_MODE=small \
    CURL_ARGS_FILE="$ssh_test_home/curl-small.args" \
    PATH="$bootstrap_bin:$PATH" bash -s -- --plan <install.sh 2>&1); then
    error 'bootstrap aceitou tarball pequeno demais'
    ((failures += 1))
elif grep -Fq 'tarball inválido: arquivo menor que 1 KiB' <<<"$bootstrap_small_output" \
    && [[ ! -e $bootstrap_small_dir ]]; then
    ok 'bootstrap rejeita tarball pequeno demais e limpa temporário'
else
    error 'bootstrap pequeno falhou sem mensagem ou limpeza esperada'
    ((failures += 1))
fi

bootstrap_curlfail_dir="$ssh_test_home/bootstrap-curlfail"
if bootstrap_curlfail_output=$(BOOTSTRAP_TEMP="$bootstrap_curlfail_dir" BOOTSTRAP_MODE=curlfail \
    CURL_ARGS_FILE="$ssh_test_home/curl-curlfail.args" \
    PATH="$bootstrap_bin:$PATH" bash -s -- --plan <install.sh 2>&1); then
    error 'bootstrap aceitou falha de curl'
    ((failures += 1))
elif grep -Fq 'falha ao baixar o tarball' <<<"$bootstrap_curlfail_output" \
    && [[ ! -e $bootstrap_curlfail_dir ]]; then
    ok 'bootstrap trata falha de curl e limpa temporário'
else
    error 'falha de curl não foi tratada com segurança'
    ((failures += 1))
fi

bootstrap_incomplete_dir="$ssh_test_home/bootstrap-incomplete"
if bootstrap_incomplete_output=$(BOOTSTRAP_TEMP="$bootstrap_incomplete_dir" BOOTSTRAP_MODE=incomplete \
    CURL_ARGS_FILE="$ssh_test_home/curl-incomplete.args" \
    PATH="$bootstrap_bin:$PATH" bash -s -- --plan <install.sh 2>&1); then
    error 'bootstrap aceitou tarball sem estrutura modular'
    ((failures += 1))
elif grep -Fq 'diretório lib/ ausente ou inválido no tarball' <<<"$bootstrap_incomplete_output" \
    && [[ ! -e $bootstrap_incomplete_dir ]]; then
    ok 'bootstrap rejeita estrutura incompleta e limpa temporário'
else
    error 'bootstrap incompleto falhou sem mensagem ou limpeza esperada'
    ((failures += 1))
fi

bootstrap_tarfail_dir="$ssh_test_home/bootstrap-tarfail"
if bootstrap_tarfail_output=$(BOOTSTRAP_TEMP="$bootstrap_tarfail_dir" BOOTSTRAP_MODE=tarfail \
    CURL_ARGS_FILE="$ssh_test_home/curl-tarfail.args" \
    PATH="$bootstrap_bin:$PATH" bash -s -- --plan <install.sh 2>&1); then
    error 'bootstrap aceitou falha de tar'
    ((failures += 1))
elif grep -Fq 'tarball inválido ou corrompido' <<<"$bootstrap_tarfail_output" \
    && [[ ! -e $bootstrap_tarfail_dir ]]; then
    ok 'bootstrap trata falha de tar e limpa temporário'
else
    error 'falha de tar não foi tratada com segurança'
    ((failures += 1))
fi

bootstrap_multiple_dir="$ssh_test_home/bootstrap-multiple"
if bootstrap_multiple_output=$(BOOTSTRAP_TEMP="$bootstrap_multiple_dir" BOOTSTRAP_MODE=multiple \
    CURL_ARGS_FILE="$ssh_test_home/curl-multiple.args" \
    PATH="$bootstrap_bin:$PATH" bash -s -- --plan <install.sh 2>&1); then
    error 'bootstrap aceitou múltiplos diretórios raiz'
    ((failures += 1))
elif grep -Fq 'tarball deve conter exatamente um diretório raiz' <<<"$bootstrap_multiple_output" \
    && [[ ! -e $bootstrap_multiple_dir ]]; then
    ok 'bootstrap rejeita múltiplos candidatos e limpa temporário'
else
    error 'bootstrap múltiplo falhou sem mensagem ou limpeza esperada'
    ((failures += 1))
fi

bootstrap_traversal_dir="$ssh_test_home/bootstrap-traversal"
if bootstrap_traversal_output=$(BOOTSTRAP_TEMP="$bootstrap_traversal_dir" BOOTSTRAP_MODE=traversal \
    CURL_ARGS_FILE="$ssh_test_home/curl-traversal.args" \
    PATH="$bootstrap_bin:$PATH" bash -s -- --plan <install.sh 2>&1); then
    error 'bootstrap aceitou path traversal no tarball'
    ((failures += 1))
elif grep -Fq 'tarball contém caminho inseguro' <<<"$bootstrap_traversal_output" \
    && [[ ! -e $bootstrap_traversal_dir ]]; then
    ok 'bootstrap rejeita path traversal e limpa temporário'
else
    error 'bootstrap traversal falhou sem mensagem ou limpeza esperada'
    ((failures += 1))
fi

bootstrap_outside_dir="$ssh_test_home/bootstrap-outside"
bootstrap_outside_target="$ssh_test_home/outside-target"
if bootstrap_outside_output=$(BOOTSTRAP_TEMP="$bootstrap_outside_dir" BOOTSTRAP_MODE=outside \
    BOOTSTRAP_OUTSIDE="$bootstrap_outside_target" CURL_ARGS_FILE="$ssh_test_home/curl-outside.args" \
    PATH="$bootstrap_bin:$PATH" bash -s -- --plan <install.sh 2>&1); then
    error 'bootstrap aceitou raiz extraída por symlink para fora do temporário'
    ((failures += 1))
elif grep -Fq 'estrutura extraída inválida' <<<"$bootstrap_outside_output" \
    && [[ ! -e $bootstrap_outside_dir ]]; then
    ok 'bootstrap rejeita candidato fora do temporário'
else
    error 'bootstrap externo falhou sem mensagem ou limpeza esperada'
    ((failures += 1))
fi

bootstrap_valid_dir="$ssh_test_home/bootstrap-valid"
curl_args="$ssh_test_home/curl-valid.args"
if bootstrap_valid_output=$(BOOTSTRAP_TEMP="$bootstrap_valid_dir" BOOTSTRAP_MODE=valid \
    CURL_ARGS_FILE="$curl_args" PATH="$bootstrap_bin:$PATH" \
    bash -s -- --plan <install.sh 2>&1) \
    && grep -Fq 'mock project loaded' <<<"$bootstrap_valid_output" \
    && grep -Fxq -- '--retry' "$curl_args" \
    && grep -Fxq -- '3' "$curl_args" \
    && grep -Fxq -- '--connect-timeout' "$curl_args" \
    && grep -Fxq -- '10' "$curl_args" \
    && grep -Fxq -- '--max-time' "$curl_args" \
    && grep -Fxq -- '120' "$curl_args" \
    && [[ ! -e $bootstrap_valid_dir ]]; then
    ok 'bootstrap válido usa retry/timeouts, reexecuta e limpa temporário'
else
    error 'bootstrap válido não respeitou download, execução ou cleanup esperados'
    ((failures += 1))
fi

invalid_bootstrap_env=0
for invalid_repo in '' \
    'http://github.com/owner/repo' \
    'https://example.com/owner/repo' \
    'https://github.com/owner/repo;echo' \
    'https://github.com/owner/repo with-space' \
    'https://github.com/owner/repo|cat' \
    "https://github.com/owner/\$repo" \
    'https://github.com/owner/repo/extra'; do
    if LEANIN_REPO=$invalid_repo BOOTSTRAP_MODE=valid \
        BOOTSTRAP_TEMP="$ssh_test_home/bootstrap-invalid-repo" \
        CURL_ARGS_FILE="$ssh_test_home/curl-invalid-repo.args" PATH="$bootstrap_bin:$PATH" \
        bash -s -- --plan <install.sh >/dev/null 2>&1; then
        error "bootstrap aceitou LEANIN_REPO inválido: $invalid_repo"
        ((failures += 1))
        invalid_bootstrap_env=1
    fi
done

for invalid_branch in '' 'bad branch' '../main' 'feature/../main' 'main..old' \
    'main;echo' 'main|cat' "main\$branch" 'feature//test'; do
    if LEANIN_BRANCH=$invalid_branch BOOTSTRAP_MODE=valid \
        BOOTSTRAP_TEMP="$ssh_test_home/bootstrap-invalid-branch" \
        CURL_ARGS_FILE="$ssh_test_home/curl-invalid-branch.args" PATH="$bootstrap_bin:$PATH" \
        bash -s -- --plan <install.sh >/dev/null 2>&1; then
        error "bootstrap aceitou LEANIN_BRANCH inválida: ${invalid_branch:-<vazia>}"
        ((failures += 1))
        invalid_bootstrap_env=1
    fi
done
(( invalid_bootstrap_env )) || ok 'bootstrap rejeita repositórios e branches inválidos'

legacy_repo_dir="$ssh_test_home/bootstrap-legacy-repo"
if legacy_repo_output=$(ARCHBOOT_REPO=https://github.com/owner/repo BOOTSTRAP_TEMP="$legacy_repo_dir" \
    BOOTSTRAP_MODE=valid CURL_ARGS_FILE="$ssh_test_home/curl-legacy-repo.args" PATH="$bootstrap_bin:$PATH" \
    bash -s -- --plan <install.sh 2>&1) \
    && grep -Fq 'mock project loaded' <<<"$legacy_repo_output" \
    && [[ ! -e $legacy_repo_dir ]] \
    && ! LEANIN_REPO=https://example.com/invalid ARCHBOOT_REPO=https://github.com/owner/repo \
        BOOTSTRAP_TEMP="$ssh_test_home/bootstrap-primary-repo" BOOTSTRAP_MODE=valid \
        CURL_ARGS_FILE="$ssh_test_home/curl-primary-repo.args" PATH="$bootstrap_bin:$PATH" \
        bash -s -- --plan <install.sh >/dev/null 2>&1; then
    ok 'LEANIN_REPO tem precedência e ARCHBOOT_REPO permanece compatível'
else
    error 'precedência ou compatibilidade de LEANIN_REPO falhou'
    ((failures += 1))
fi

missing_tool_bin="$ssh_test_home/missing-tool-bin"
mkdir -p "$missing_tool_bin"
ln -s "$(type -P bash)" "$missing_tool_bin/bash"
if missing_curl_output=$(PATH="$missing_tool_bin" "$missing_tool_bin/bash" -s -- --plan <install.sh 2>&1); then
    error 'bootstrap aceitou ausência de curl'
    ((failures += 1))
elif grep -Fq 'curl é necessário para baixar o projeto completo' <<<"$missing_curl_output"; then
    ok 'bootstrap informa ausência de curl'
else
    error 'ausência de curl falhou sem mensagem clara'
    ((failures += 1))
fi

ln -s "$(type -P curl)" "$missing_tool_bin/curl"
if missing_tar_output=$(PATH="$missing_tool_bin" "$missing_tool_bin/bash" -s -- --plan <install.sh 2>&1); then
    error 'bootstrap aceitou ausência de tar'
    ((failures += 1))
elif grep -Fq 'tar é necessário para extrair o projeto completo' <<<"$missing_tar_output"; then
    ok 'bootstrap informa ausência de tar'
else
    error 'ausência de tar falhou sem mensagem clara'
    ((failures += 1))
fi

ln -s "$(type -P tar)" "$missing_tool_bin/tar"
if missing_mktemp_output=$(PATH="$missing_tool_bin" "$missing_tool_bin/bash" -s -- --plan <install.sh 2>&1); then
    error 'bootstrap aceitou ausência de mktemp'
    ((failures += 1))
elif grep -Fq 'mktemp é necessário para criar um diretório temporário seguro' <<<"$missing_mktemp_output"; then
    ok 'bootstrap informa ausência de mktemp'
else
    error 'ausência de mktemp falhou sem mensagem clara'
    ((failures += 1))
fi

local_curl_marker="$ssh_test_home/local-curl-called"
cat >"$bootstrap_bin/curl" <<EOF
#!/usr/bin/env bash
touch "$local_curl_marker"
exit 90
EOF
chmod +x "$bootstrap_bin/curl"
if PATH="$bootstrap_bin:$PATH" bash install.sh --plan >/dev/null 2>&1 \
    && [[ ! -e $local_curl_marker ]]; then
    ok '--plan local não aciona bootstrap remoto'
else
    error '--plan local tentou usar curl/bootstrap remoto'
    ((failures += 1))
fi

redaction_log="$ssh_test_home/redaction.log"
if redaction_output=$(bash -c '
    set -Eeuo pipefail
    source lib/log
    source lib/run
    DRY_RUN=0
    VERBOSE=0
    LOG_FILE=$1
    github_token="gh""p_TESTTOKEN123"
    fine_token="github_""pat_TESTTOKEN456"
    slack_token="xox""b-123456-secret"
    authorization="Authorization: ""Bearer $github_token"
    private_begin="-----BEGIN OPENSSH PRIVATE ""KEY-----"
    private_end="-----END OPENSSH PRIVATE ""KEY-----"
    run_cmd redaction printf "%s\n" \
        "$github_token" "$fine_token" "$slack_token" "$authorization" \
        "$private_begin" private-material "$private_end"
    DRY_RUN=1
    dry_run_msg curl -H "$authorization" https://example.invalid
' _ "$redaction_log" 2>&1) \
    && grep -Fq '[REDACTED_GITHUB_TOKEN]' "$redaction_log" \
    && grep -Fq '[REDACTED_SLACK_TOKEN]' "$redaction_log" \
    && grep -Fq '[REDACTED PRIVATE KEY]' "$redaction_log" \
    && grep -Fq '[REDACTED_GITHUB_TOKEN]' <<<"$redaction_output" \
    && ! grep -Eq 'TESTTOKEN|private-material|123456-secret' "$redaction_log" \
    && ! grep -Eq 'TESTTOKEN|123456-secret' <<<"$redaction_output"; then
    ok 'logs e dry-run removem tokens, bearer e blocos de chave privada'
else
    error 'redaction de logs ou output falhou'
    ((failures += 1))
fi

state_home="$ssh_test_home/state-home"
if HOME="$ssh_test_home" XDG_STATE_HOME="$state_home" bash -c '
    set -Eeuo pipefail
    source lib/log
    source lib/env
    state
    [[ $LEANIN_STATE_DIR == "$XDG_STATE_HOME/leanin" ]]
    [[ $(stat -c %a "$LEANIN_STATE_DIR") == 700 ]]
    [[ $(stat -c %a "$LEANIN_LOG_DIR") == 700 ]]
    [[ $(stat -c %a "$LOG_FILE") == 600 ]]
'; then
    ok 'logs do leanin usam caminho e permissões restritas'
else
    error 'permissões de logs não são 700/600'
    ((failures += 1))
fi

if grep -REn 'cat[[:space:]]+.*(SSH_PRIVATE_KEY|id_ed25519([^.]|$))' lib install.sh >/dev/null 2>&1; then
    error 'código tenta imprimir conteúdo de chave SSH privada'
    ((failures += 1))
else
    ok 'nenhuma chave SSH privada é lida com cat'
fi

ssh_normalize() {
    HOME=$ssh_test_home bash -c \
        'source lib/log; source lib/ssh; _normalize_ssh_key_path "$1"' _ "$1"
}
if [[ $(ssh_normalize test) == "$ssh_test_home/.ssh/test" \
    && $(ssh_normalize keys/personal) == "$ssh_test_home/.ssh/keys/personal" ]] \
    && ! ssh_normalize ../outside >/dev/null 2>&1 \
    && ! ssh_normalize /tmp/outside >/dev/null 2>&1; then
    ok 'caminhos SSH ficam restritos a ~/.ssh'
else
    error 'normalização de caminho SSH insegura'
    ((failures += 1))
fi

if grep -Fq '_github_default_title()' lib/gh \
    && grep -Fq "printf 'leanin-%s-%s'" lib/gh; then
    ok 'título padrão da chave GitHub identifica a máquina'
else
    error 'título padrão da chave GitHub não identifica a máquina'
    ((failures += 1))
fi
if grep -Fq "yesno 'remover chaves SSH antigas do GitHub que não são a chave atual?' n" lib/gh \
    && grep -Fq 'GITHUB_OLD_KEY_IDS' lib/gh \
    && ! grep -Fq 'Deletar TODAS as SSH keys antigas do GitHub?' lib/gh \
    && ! grep -Fq 'Digite DELETE' lib/gh; then
    ok 'limpeza GitHub usa confirmação única com default não'
else
    error 'confirmação GitHub não usa o fluxo s/N esperado'
    ((failures += 1))
fi
# Os tokens abaixo verificam o código-fonte literal.
# shellcheck disable=SC2016
if grep -Fq 'ask_reconfigure()' lib/ask \
    && grep -Fq "'identidade Git já configurada'" lib/git \
    && grep -Fq "'chave SSH local já existe'" lib/ssh \
    && grep -Fq '_backup_ssh_key' lib/ssh \
    && grep -Fq 'mv -- "$private_key" "$backup_private"' lib/ssh \
    && grep -Fq 'UserKnownHostsFile=/dev/null' lib/ssh \
    && grep -Fq "'Codex já existe em ~/.codex/bin/codex'" lib/codex \
    && grep -Fq 'ask_additive' lib/codex \
    && grep -Fq 'flatpak remote-modify --url' lib/flatpak \
    && grep -Fq 'flathub já existe com configuração diferente' lib/flatpak \
    && grep -Fq 'serviço $service está inativo' lib/service; then
    ok 'reconfigurações existentes exigem confirmação e SSH cria backup'
else
    error 'confirmações ou backup de reconfiguração estão ausentes'
    ((failures += 1))
fi
if rg -n 'ask_(reconfigure|additive)' lib/pkg lib/aur >/dev/null 2>&1; then
    error 'instalação de pacotes passou a pedir confirmação individual'
    ((failures += 1))
else
    ok 'pacotes já instalados continuam sendo apenas pulados'
fi
if grep -Eq '(rm|unlink)[[:space:]].*(\.ssh|SSH_PRIVATE_KEY|SSH_PUBLIC_KEY)' lib/ssh lib/gh; then
    error 'fluxo GitHub tenta deletar arquivos SSH locais'
    ((failures += 1))
else
    ok 'fluxo GitHub não deleta arquivos SSH locais'
fi
if grep -REn '(^|[[:space:]])(yay|paru|pacman)[[:space:]]+-R' install.sh lib scripts >/dev/null 2>&1; then
    error 'comando de remoção automática de pacotes encontrado'
    ((failures += 1))
else
    ok 'nenhuma remoção automática de pacotes encontrada'
fi
if grep -Fq 'github_manual_ssh_key()' lib/gh \
    && grep -Fq 'GITHUB_KEYS_URL' lib/gh; then
    ok 'fallback manual de SSH permanece disponível'
else
    error 'fallback manual de SSH ausente'
    ((failures += 1))
fi

step 5 10 'validando controles do instalador'
controls_fail=0
if version_output=$(bash install.sh --version 2>&1) \
    && piped_version_output=$(set -o pipefail; sed -n p install.sh | bash -s -- --version) \
    && [[ $version_output == 'leanin 0.1.1' ]] \
    && [[ $piped_version_output == 'leanin 0.1.1' ]] \
    && grep -Fq '## v0.1.1' CHANGELOG.md; then
    ok 'versão 0.1.1 consistente'
else
    error 'install.sh --version ou CHANGELOG está inconsistente'
    controls_fail=1
fi

if ! help_output=$(bash install.sh --help 2>&1); then
    error '--help retornou status diferente de zero'
    controls_fail=1
    help_output=''
fi
help_flags=(
    --dry-run --verbose --plan --doctor --version --yes --no-packages --no-pacman
    --no-flatpak --no-aur --no-services --no-codex --no-git --no-ssh --no-github
)
for flag in "${help_flags[@]}"; do
    if ! grep -Fq -- "$flag" <<<"$help_output"; then
        error "--help não contém $flag"
        controls_fail=1
    fi
done

if unknown_output=$(bash install.sh --unknown-flag 2>&1); then
    error 'flag desconhecida retornou sucesso'
    controls_fail=1
elif grep -Fq 'opção desconhecida: --unknown-flag' <<<"$unknown_output"; then
    ok 'flag desconhecida falha com mensagem clara'
else
    error 'flag desconhecida falhou sem mensagem clara'
    controls_fail=1
fi
if bash install.sh --version --unknown-flag >/dev/null 2>&1; then
    error '--version ignorou flag desconhecida combinada'
    controls_fail=1
else
    ok '--version não ignora argumentos inválidos'
fi

if plan_output=$(bash install.sh --plan 2>&1) \
    && grep -Fq 'leanin 0.1.1' <<<"$plan_output" \
    && grep -Fq '> [ok] pacman: 11 pacotes' <<<"$plan_output" \
    && grep -Fq '> [ok] Flatpak: 6 apps' <<<"$plan_output" \
    && grep -Fq '> [ok] AUR: 3 pacotes' <<<"$plan_output" \
    && grep -Fq '> [ok] serviços system: 1 serviço' <<<"$plan_output" \
    && grep -Fq '> [ok] serviços user: 0 serviços' <<<"$plan_output" \
    && grep -Fq '> [info] Codex: habilitado' <<<"$plan_output" \
    && grep -Fq '> [info] Git: habilitado' <<<"$plan_output" \
    && grep -Fq '> [info] SSH/GitHub: habilitado' <<<"$plan_output" \
    && ! grep -Fq '[ask]' <<<"$plan_output" \
    && ! grep -Fq '> Etapa' <<<"$plan_output" \
    && ! grep -Eq '(pacman -S|flatpak (install|remote-add)|yay -S|paru -S|systemctl .*enable|npm (config|install)|gh (auth|ssh-key)|ssh-keygen)' <<<"$plan_output"; then
    ok '--plan é somente leitura e não interativo'
else
    error '--plan não produziu o plano resumido esperado'
    controls_fail=1
fi

if verbose_plan_output=$(bash install.sh --plan --verbose 2>&1) \
    && grep -Fqx 'pacman' <<<"$verbose_plan_output" \
    && grep -Fq 'audio      easyeffects' <<<"$verbose_plan_output" \
    && grep -Fq 'base ' <<<"$verbose_plan_output" \
    && grep -Fqx 'Flatpak' <<<"$verbose_plan_output" \
    && grep -Fq 'chat ' <<<"$verbose_plan_output" \
    && grep -Fq 'games ' <<<"$verbose_plan_output" \
    && grep -Fq 'org.vinegarhq.Sober' <<<"$verbose_plan_output" \
    && grep -Fqx 'AUR' <<<"$verbose_plan_output" \
    && grep -Fq 'browsers ' <<<"$verbose_plan_output" \
    && grep -Fqx 'serviços' <<<"$verbose_plan_output" \
    && grep -Fq 'system ' <<<"$verbose_plan_output" \
    && ! grep -Fq 'categories' <<<"$verbose_plan_output" \
    && ! grep -Fq '[ask]' <<<"$verbose_plan_output"; then
    ok '--plan --verbose permanece somente leitura'
else
    error '--plan --verbose falhou ou pediu input'
    controls_fail=1
fi

if no_flatpak_output=$(LEANIN_CI=1 bash install.sh --dry-run --no-flatpak --no-ssh --no-github 2>&1) \
    && grep -Fq '[skip] Flatpak desativado por flag' <<<"$no_flatpak_output" \
    && ! grep -Fq 'org.vinegarhq.Sober' <<<"$no_flatpak_output"; then
    ok '--no-flatpak não processa Sober'
else
    error '--no-flatpak não pulou Sober corretamente'
    controls_fail=1
fi

if no_packages_output=$(LEANIN_CI=1 bash install.sh --dry-run --no-packages --no-ssh --no-github 2>&1) \
    && grep -Fq '[skip] Flatpak desativado por flag' <<<"$no_packages_output" \
    && ! grep -Fq 'org.vinegarhq.Sober' <<<"$no_packages_output"; then
    ok '--no-packages não processa Sober'
else
    error '--no-packages não pulou Sober corretamente'
    controls_fail=1
fi

if grep -RE '(yesno|ask_[a-z_]+).*org\.vinegarhq\.Sober' install.sh lib >/dev/null 2>&1; then
    error 'Sober introduziu prompt por pacote'
    controls_fail=1
else
    ok 'Sober não introduz prompt por pacote'
fi

if [[ -r /etc/os-release ]] && grep -Eq '^ID=arch$|^ID_LIKE=.*arch' /etc/os-release; then
    doctor_status=0
    doctor_output=$(bash install.sh --doctor 2>&1) || doctor_status=$?
    if grep -Fq $'doctor\n\nsistema' <<<"$doctor_output" \
        && grep -Fq $'pacotes\n' <<<"$doctor_output" \
        && grep -Fq $'ferramentas\n' <<<"$doctor_output" \
        && grep -Fq $'integrações\n' <<<"$doctor_output" \
        && grep -Fq $'serviços\n' <<<"$doctor_output" \
        && ! grep -Fq '[ask]' <<<"$doctor_output"; then
        if (( doctor_status == 0 )) && grep -Fq '[ok] diagnóstico concluído' <<<"$doctor_output"; then
            ok '--doctor local é somente leitura e não interativo'
        elif grep -Fq '[error] diagnóstico encontrou' <<<"$doctor_output"; then
            skip '--doctor local encontrou um problema real do host; modo permanece somente leitura'
        else
            error '--doctor local retornou diagnóstico incompleto'
            controls_fail=1
        fi
    else
        error '--doctor local falhou'
        controls_fail=1
    fi
else
    skip '--doctor local requer host Arch; validação portátil será usada'
fi

if ci_doctor_output=$(LEANIN_CI=1 bash install.sh --doctor 2>&1) \
    && grep -Fq $'doctor\n\nsistema' <<<"$ci_doctor_output" \
    && grep -Fq '[info] modo CI: diagnóstico do host pulado' <<<"$ci_doctor_output" \
    && grep -Fq '[ok] lista services/system disponível' <<<"$ci_doctor_output" \
    && grep -Fq '[ok] diagnóstico concluído' <<<"$ci_doctor_output" \
    && ! grep -Fq '[ask]' <<<"$ci_doctor_output"; then
    ok 'LEANIN_CI=1 aceita --doctor'
else
    error 'LEANIN_CI=1 --doctor falhou'
    controls_fail=1
fi
if legacy_ci_output=$(ARCHBOOT_CI=1 bash install.sh --doctor 2>&1) \
    && grep -Fq '[info] modo CI: diagnóstico do host pulado' <<<"$legacy_ci_output" \
    && grep -Fq '[ok] diagnóstico concluído' <<<"$legacy_ci_output"; then
    ok 'ARCHBOOT_CI=1 permanece como alias de compatibilidade'
else
    error 'ARCHBOOT_CI=1 não preservou compatibilidade'
    controls_fail=1
fi

doctor_mutation_regex='pacman[[:space:]]+-S|flatpak[[:space:]]+(install|remote-add)|(^|[[:space:]])(yay|paru)[[:space:]]+-S|npm[[:space:]]+install|gh[[:space:]]+ssh-key[[:space:]]+(add|delete)|systemctl([^[:cntrl:]]*)enable([^[:cntrl:]]*)--now'
if grep -En "$doctor_mutation_regex" lib/doctor >/dev/null 2>&1; then
    error '--doctor contém comando mutável'
    controls_fail=1
else
    ok '--doctor não contém comandos de instalação, cadastro ou ativação'
fi

if ci_plan_output=$(LEANIN_CI=1 bash install.sh --plan 2>&1) \
    && grep -Fq 'pacman: 11 pacotes' <<<"$ci_plan_output"; then
    ok 'LEANIN_CI=1 aceita --plan'
else
    error 'LEANIN_CI=1 --plan falhou'
    controls_fail=1
fi

plan_flag_cases=(
    '--no-pacman|pacman: desativado'
    '--no-flatpak|Flatpak: desativado'
    '--no-aur|AUR: desativado'
    '--no-services|serviços system: desativado'
    '--no-codex|Codex: desativado'
    '--no-git|Git: desativado'
    '--no-github|GitHub: desativado'
)
for plan_case in "${plan_flag_cases[@]}"; do
    flag=${plan_case%%|*}
    expected=${plan_case#*|}
    if ! flag_output=$(bash install.sh --plan "$flag" 2>&1) \
        || ! grep -Fq "$expected" <<<"$flag_output"; then
        error "$flag não alterou o plano como esperado"
        controls_fail=1
    fi
done

ci_args=(
    --dry-run --no-packages --no-services --no-ssh --no-github --no-codex
)
if ci_dry_output=$(LEANIN_CI=1 bash install.sh "${ci_args[@]}" 2>&1) \
    && grep -Fq '[ok] modo CI dry-run' <<<"$ci_dry_output" \
    && grep -Fq '[skip] pacman desativado por flag' <<<"$ci_dry_output" \
    && grep -Fq '[skip] Flatpak desativado por flag' <<<"$ci_dry_output" \
    && grep -Fq '[skip] AUR desativado por flag' <<<"$ci_dry_output" \
    && grep -Fq '[skip] serviços desativados por flag' <<<"$ci_dry_output" \
    && grep -Fq '[skip] Codex desativado por flag' <<<"$ci_dry_output" \
    && grep -Fq '[skip] SSH desativado por flag' <<<"$ci_dry_output" \
    && grep -Fq '[skip] GitHub desativado por flag' <<<"$ci_dry_output" \
    && grep -Fq '[info] pacman: 0 planejados, 0 pulados' <<<"$ci_dry_output" \
    && grep -Fq '[info] desativados por flag:' <<<"$ci_dry_output" \
    && ! grep -Fq 'log: /dev/null' <<<"$ci_dry_output" \
    && ! grep -Eq '\[dry-run\].*(pacman -S|flatpak (install|remote-add)|yay -S|paru -S|systemctl .*enable|npm install|gh (auth|ssh-key)|ssh-keygen)' <<<"$ci_dry_output"; then
    ok 'CI dry-run respeita flags sem executar fontes desativadas'
else
    error 'CI dry-run ou flags --no-* falharam'
    controls_fail=1
fi

layout_args=(--dry-run --no-packages --no-services --no-codex --no-git --no-ssh --no-github)
if layout_output=$(LEANIN_CI=1 bash install.sh "${layout_args[@]}" 2>&1) \
    && grep -Fq '> Etapa 1/3: sistema' <<<"$layout_output" \
    && grep -Fq '> Etapa 2/3: plano' <<<"$layout_output" \
    && grep -Fq '> Etapa 3/3: resumo' <<<"$layout_output" \
    && grep -Fq $'pacotes\n> [info]' <<<"$layout_output" \
    && grep -Fq $'configuração\n> [info]' <<<"$layout_output" \
    && ! grep -Fq 'finalizando integrações' <<<"$layout_output" \
    && ! grep -Fq '> Etapa 4/' <<<"$layout_output"; then
    ok 'etapas ativas usam total dinâmico e resumo separado'
else
    error 'ordem ou total das etapas ativas está inconsistente'
    controls_fail=1
fi

if default_dry_output=$(LEANIN_CI=1 bash install.sh --dry-run --no-ssh --no-github 2>&1) \
    && grep -Fq '> Etapa 10/10: resumo' <<<"$default_dry_output" \
    && grep -Fq '> [ok] dry-run concluído' <<<"$default_dry_output"; then
    ok 'dry-run sem flags de fonte conclui todas as etapas ativas'
else
    error 'dry-run sem flags de fonte encerrou antes do resumo'
    controls_fail=1
fi

if output_quality=$(LEANIN_CI=1 bash install.sh --dry-run --no-ssh --no-github 2>&1) \
    && grep -Fq '> [dry-run]' <<<"$output_quality" \
    && grep -Fq $'pacotes\n> [info]' <<<"$output_quality" \
    && grep -Fq $'configuração\n> [info]' <<<"$output_quality" \
    && ! grep -Fq 'finalizando integrações' <<<"$output_quality" \
    && ! grep -Fq 'Identity added:' <<<"$output_quality" \
    && ! grep -Fq 'ssh_askpass:' <<<"$output_quality" \
    && awk 'NF == 0 { blank += 1; if (blank > 2) exit 1 } NF != 0 { blank = 0 }' \
        <<<"$output_quality"; then
    ok 'dry-run mantém grupos, espaçamento e saída limpa'
else
    error 'dry-run perdeu agrupamento, espaçamento ou silêncio de comandos internos'
    controls_fail=1
fi

if ! grep -Fq 'next_step' install.sh \
    || grep -Fq "next_step 'finalizando integrações'" install.sh; then
    error 'fluxo ainda contém etapa final vazia ou sem contador centralizado'
    controls_fail=1
else
    ok 'fluxo não contém etapa final vazia'
fi

if plan_log_output=$(LEANIN_CI=1 bash install.sh --plan 2>&1) \
    && ! grep -Fq 'log criado:' <<<"$plan_log_output"; then
    ok '--plan não cria nem anuncia log de execução'
else
    error '--plan criou ou anunciou log de execução'
    controls_fail=1
fi

yes_args=(--dry-run --yes --no-packages --no-services --no-ssh --no-github --no-codex --no-git)
if yes_output=$(LEANIN_CI=1 bash install.sh "${yes_args[@]}" 2>&1) \
    && ! grep -Fq '[ask]' <<<"$yes_output" \
    && grep -Fq '[skip] SSH desativado por flag' <<<"$yes_output"; then
    ok '--yes combinado com --no-* não bloqueia nem executa ações desativadas'
else
    error '--yes combinado com --no-* falhou ou pediu input'
    controls_fail=1
fi

no_ssh_args=(--dry-run --no-packages --no-services --no-ssh --no-codex)
if no_ssh_output=$(LEANIN_CI=1 bash install.sh "${no_ssh_args[@]}" 2>&1) \
    && grep -Fq '[skip] SSH desativado por flag' <<<"$no_ssh_output" \
    && grep -Fq '[skip] GitHub desativado por flag' <<<"$no_ssh_output" \
    && grep -Fq 'GitHub SSH: desativado por flag' <<<"$no_ssh_output"; then
    ok '--no-ssh implica --no-github'
else
    error '--no-ssh não desativou a integração GitHub'
    controls_fail=1
fi

if no_github_output=$(LEANIN_CI=1 bash install.sh --dry-run --no-packages --no-services --no-codex --no-git --no-github 2>&1) \
    && grep -Fq '[skip] GitHub desativado por flag' <<<"$no_github_output" \
    && grep -Fq '> Etapa 3/4: SSH' <<<"$no_github_output" \
    && ! grep -Fq '> Etapa 4/4: GitHub' <<<"$no_github_output"; then
    ok '--no-github pula somente a integração GitHub'
else
    error '--no-github também pulou SSH ou manteve etapa GitHub'
    controls_fail=1
fi

if help_output=$(bash install.sh --help 2>&1) \
    && grep -Fq 'Uso: bash install.sh [opções]' <<<"$help_output" \
    && ! grep -Fq 'baixando projeto completo' <<<"$help_output"; then
    ok '--help encerra antes do bootstrap remoto'
else
    error '--help tentou bootstrap ou não mostrou a ajuda'
    controls_fail=1
fi

if LEANIN_CI=1 bash install.sh >/dev/null 2>&1; then
    error 'LEANIN_CI=1 permitiu execução sem --dry-run/--plan'
    controls_fail=1
else
    ok 'LEANIN_CI=1 bloqueia execução mutável'
fi
if LEANIN_CI=invalid bash install.sh --plan >/dev/null 2>&1; then
    error 'LEANIN_CI inválido foi aceito'
    controls_fail=1
else
    ok 'LEANIN_CI inválido falha de forma explícita'
fi

# A expressão é intencionalmente literal para validar o código-fonte.
# shellcheck disable=SC2016
if grep -Fq 'elif (( DRY_RUN )); then' install.sh \
    && grep -Fq "ok 'dry-run concluído'" install.sh \
    && grep -Fq 'error "concluído com $failure_count falha(s)"' install.sh \
    && grep -Fq 'summary_counts pacman' install.sh \
    && grep -Fq 'summary_counts serviços' install.sh; then
    ok 'resumo distingue sucesso, falhas e contagens por fonte'
else
    error 'resumo final não preserva diagnóstico e contagens esperados'
    controls_fail=1
fi

if bash -c '
    set -Eeuo pipefail
    source lib/ask
    ASSUME_YES=1
    if yesno "ação perigosa" n; then exit 1; fi
    yesno "ação segura" s
    value=unexpected
    prompt value "valor" safe-default
    [[ $value == safe-default ]]
'; then
    ok '--yes preserva defaults seguros'
else
    error '--yes confirmou ação com default não ou pediu input'
    controls_fail=1
fi

ask_prompt_test() {
    local input=$1 expected=$2 command='' output='' status=0

    printf -v command 'set -Eeuo pipefail; source %q; source %q; yesno %q n' \
        "$ROOT/lib/log" "$ROOT/lib/ask" 'teste'
    if output=$(printf '%b' "$input" | script -qec "$command" /dev/null 2>&1); then
        status=0
    else
        status=$?
    fi
    [[ $status == "$expected" ]] \
        && grep -Fq '> [?] teste [s/N]' <<<"$output"
}

ask_prompt_value_test() {
    local command='' output=''

    # $value deve ser expandido pelo shell dentro do pseudo-terminal.
    # shellcheck disable=SC2016
    printf -v command 'set -Eeuo pipefail; source %q; source %q; prompt value %q %q; [[ $value == %q ]]' \
        "$ROOT/lib/log" "$ROOT/lib/ask" 'título' 'person' 'personal'
    output=$(printf 'personal\n' | script -qec "$command" /dev/null 2>&1) \
        && grep -Fq '> [?] título [person]:' <<<"$output"
}

if command -v script >/dev/null 2>&1 \
    && ask_prompt_test '\n' 1 \
    && ask_prompt_test 'n\n' 1 \
    && ask_prompt_test 'N\n' 1 \
    && ask_prompt_test 's\n' 0 \
    && ask_prompt_test 'S\n' 0 \
    && ask_prompt_test 'inválido\ns\n' 0 \
    && ask_prompt_value_test; then
    ok 'prompts usam /dev/tty mesmo quando stdin vem de pipe'
elif ! command -v script >/dev/null 2>&1; then
    skip 'teste de pseudo-terminal indisponível (script ausente)'
else
    error 'prompt s/N não leu /dev/tty ou não preservou respostas esperadas'
    controls_fail=1
fi

if command -v setsid >/dev/null 2>&1 \
    && ! setsid bash -c '
        set -Eeuo pipefail
        source lib/log
        source lib/ask
        yesno "teste sem tty" n
    ' </dev/null >/dev/null 2>&1; then
    ok 'prompts sem /dev/tty usam default seguro sem travar'
elif ! command -v setsid >/dev/null 2>&1; then
    skip 'teste sem terminal indisponível (setsid ausente)'
else
    error 'prompt sem /dev/tty não retornou o default seguro'
    controls_fail=1
fi

if bash -c '
    set -Eeuo pipefail
    source lib/ask
    _ask_read_tty() { exit 99; }
    ASSUME_YES=1
    if yesno "teste" n; then exit 1; fi
    value=unexpected
    prompt value "teste" default
    [[ $value == default ]]
    unset ASSUME_YES
    DRY_RUN=1
    if yesno "teste" n; then exit 1; fi
    if ask_reconfigure "teste"; then exit 1; fi
    value=unexpected
    prompt value "teste" default
    [[ $value == default ]]
    DRY_RUN=0
    PLAN_ONLY=1
    if yesno "teste" n; then exit 1; fi
    if ask_reconfigure "teste"; then exit 1; fi
    PLAN_ONLY=0
    DOCTOR_ONLY=1
    if yesno "teste" n; then exit 1; fi
    if ask_reconfigure "teste"; then exit 1; fi
    DOCTOR_ONLY=0
    CI_MODE=1
    if yesno "teste" n; then exit 1; fi
    if ask_reconfigure "teste"; then exit 1; fi
' >/dev/null 2>&1; then
    ok 'dry-run, --yes, --plan, --doctor e CI não leem prompts'
else
    error 'modo não interativo tentou ler /dev/tty'
    controls_fail=1
fi

if pipe_dry_output=$(printf '\n' | timeout 15 env LEANIN_CI=1 bash install.sh --dry-run \
    --no-packages --no-services --no-codex --no-git --no-ssh --no-github 2>&1) \
    && ! grep -Fq '> [?]' <<<"$pipe_dry_output"; then
    ok 'stdin em pipe não trava o dry-run'
else
    error 'dry-run com stdin em pipe travou ou pediu input'
    controls_fail=1
fi

doctor_home="$ssh_test_home/doctor-home"
if HOME="$doctor_home" LEANIN_ROOT="$ROOT" CI_MODE=1 bash -c '
    set -Eeuo pipefail
    source lib/log
    source lib/env
    source lib/doctor
    doctor_run
    [[ ! -e $HOME/.ssh && ! -e $HOME/.codex && ! -e $HOME/.config ]]
' >/dev/null 2>&1; then
    ok 'doctor CI não cria arquivos no HOME temporário'
else
    error 'doctor CI criou estado no HOME temporário'
    controls_fail=1
fi

if ask_reconfigure_output=$(bash -c '
    set -Eeuo pipefail
    source lib/ask
    DRY_RUN=1
    if ask_reconfigure "configuração existente"; then exit 1; fi
' 2>&1) \
    && grep -Fq '[dry-run] perguntaria se deve refazer configuração existente' <<<"$ask_reconfigure_output" \
    && bash -c '
        set -Eeuo pipefail
        source lib/ask
        ASSUME_YES=1
        if ask_reconfigure "configuração existente"; then exit 1; fi
    '; then
    ok 'reconfiguração usa default não em dry-run e --yes'
else
    error 'reconfiguração não preserva default seguro'
    controls_fail=1
fi

if bash -c '
    set -Eeuo pipefail
    source lib/log
    source lib/ask
    source lib/git
    ASSUME_YES=1
    DRY_RUN=0
    LOG_FILE=/dev/null
    GIT_NAME=""
    GIT_EMAIL=""
    FAILURES=()
    git() {
        if [[ $1 == config && $2 == --global && $3 == --get ]]; then
            case $4 in
                user.name) printf "existing name\n" ;;
                user.email) printf "existing@example.test\n" ;;
                init.defaultBranch) printf "main\n" ;;
                pull.rebase) printf "false\n" ;;
                core.editor) printf "code --wait\n" ;;
            esac
            return 0
        fi
        exit 91
    }
    command_exists() { [[ $1 != code ]]; }
    run_cmd() { exit 90; }
    configure_git
    [[ $GIT_NAME == "existing name" ]]
    [[ $GIT_EMAIL == "existing@example.test" ]]
' >/dev/null 2>&1; then
    ok '--yes não sobrescreve identidade Git existente'
else
    error '--yes tentou sobrescrever identidade Git existente'
    controls_fail=1
fi

if bash -c '
    set -Eeuo pipefail
    source lib/log
    source lib/ask
    source lib/git
    ASSUME_YES=1
    DRY_RUN=0
    LOG_FILE=/dev/null
    git() { printf "master\n"; }
    run_cmd() { exit 90; }
    _configure_git_value init.defaultBranch main "branch padrão Git"
' >/dev/null 2>&1; then
    ok '--yes não troca preferências Git existentes'
else
    error '--yes tentou trocar preferência Git existente'
    controls_fail=1
fi

if bash -c '
    set -Eeuo pipefail
    source lib/log
    source lib/ask
    source lib/git
    DRY_RUN=0
    LOG_FILE=/dev/null
    FAILURES=()
    git() { return 1; }
    run_cmd() { return 1; }
    if _configure_git_identity name user@example.test; then exit 1; fi
    [[ ${FAILURES[*]} == *git:identity* ]]
    if _configure_git_value init.defaultBranch main "branch padrão Git"; then exit 1; fi
    [[ ${FAILURES[*]} == *git:init.defaultBranch* ]]
' >/dev/null 2>&1; then
    ok 'falhas de configuração Git são registradas'
else
    error 'falhas de configuração Git foram tratadas como sucesso'
    controls_fail=1
fi

if bash -c '
    set -Eeuo pipefail
    source lib/log
    source lib/ask
    source lib/service
    LOG_FILE=/dev/null
    FAILURES=()
    SYSTEM_SERVICES=(mock.service)
    USER_SERVICES=(mock-user.service)
    command_exists() { [[ $1 != systemctl ]]; }
    activate_services
    ((${#SERVICES_SKIPPED[@]} == 2))
    ((${#FAILURES[@]} == 0))
' >/dev/null 2>&1; then
    ok 'systemctl ausente pula serviços sem sucesso falso'
else
    error 'systemctl ausente não foi tratado de forma segura'
    controls_fail=1
fi

if (( controls_fail )); then
    ((failures += 1))
fi

fake_bin="$ssh_test_home/bin"
sudo_marker="$ssh_test_home/sudo-marker"
mkdir -p "$fake_bin"
cat >"$fake_bin/sudo" <<EOF
#!/usr/bin/env bash
printf '%s\n' "\$*" >>"$sudo_marker"
EOF
chmod +x "$fake_bin/sudo"
if PATH="$fake_bin:$PATH" SUDO_MARKER="$sudo_marker" bash -c '
    set -Eeuo pipefail
    source lib/log
    source lib/run
    sudo() { return 0; }
    DRY_RUN=0
    VERBOSE=0
    LOG_FILE=/dev/null
    run_sudo "mock sudo" pacman -S mock-package
' >/dev/null 2>&1 \
    && grep -Fqx -- '-- pacman -S mock-package' "$sudo_marker"; then
    ok 'run_sudo usa o binário sudo, não a função de validação'
else
    error 'run_sudo não executou o binário sudo esperado'
    ((failures += 1))
fi

ssh_add_log="$ssh_test_home/ssh-add.log"
mkdir -p "$fake_bin"
cat >"$fake_bin/ssh-add" <<'EOF'
#!/usr/bin/env bash
if [[ -n ${SSH_ADD_MARKER:-} ]]; then
    exec 3>>"$SSH_ADD_MARKER"
    printf 'askpass=%s require=%s\n' "${SSH_ASKPASS-unset}" "${SSH_ASKPASS_REQUIRE-unset}" >&3
    for fd in 0 1 2; do
        printf 'fd%s=' "$fd" >&3
        readlink "/proc/$$/fd/$fd" >&3
    done
    exec 3>&-
fi
printf 'Identity added: %s (mock)\n' "${1:-unknown}"
EOF
chmod +x "$fake_bin/ssh-add"
mkdir -p "$ssh_test_home/.ssh"
printf 'private mock\n' >"$ssh_test_home/.ssh/id_ed25519"
printf 'ssh-ed25519 AAAATEST mock@example\n' >"$ssh_test_home/.ssh/id_ed25519.pub"
if ssh_add_output=$(HOME="$ssh_test_home" PATH="$fake_bin:$PATH" SSH_AUTH_SOCK=mock \
    bash -c '
        set -Eeuo pipefail
        source lib/log
        source lib/ask
        source lib/env
        source lib/run
        source lib/ssh
        DRY_RUN=0
        VERBOSE=0
        LOG_FILE=$1
        FAILURES=()
        GIT_EMAIL=mock@example
        # A regression test must never consult the terminal or answer.
        ask_reconfigure() { return 1; }
        _ssh_tty_path() { printf "%s" "$HOME/tty-unavailable"; }
        configure_ssh
    ' _ "$ssh_add_log" 2>&1) \
    && ! grep -Fq 'Identity added:' <<<"$ssh_add_output" \
    && ! grep -Fq 'ssh-keygen' <<<"$ssh_add_output" \
    && grep -Fq 'não há terminal disponível para adicionar a chave ao ssh-agent' <<<"$ssh_add_output" \
    && [[ ! -e $ssh_add_log ]]; then
    ok 'chave SSH existente é mantida sem chamar ssh-add fora do terminal'
else
    error 'chave SSH existente foi refeita ou ssh-add ignorou o terminal'
    ((failures += 1))
fi

ssh_add_tty="$ssh_test_home/ssh-add.tty"
ssh_add_marker="$ssh_test_home/ssh-add.marker"
: >"$ssh_add_tty"
: >"$ssh_add_marker"
if ssh_add_tty_output=$(HOME="$ssh_test_home" PATH="$fake_bin:$PATH" SSH_AUTH_SOCK=mock \
    SSH_ADD_MARKER="$ssh_add_marker" TTY_FILE="$ssh_add_tty" bash -c '
        set -Eeuo pipefail
        source lib/log
        source lib/ask
        source lib/env
        source lib/run
        source lib/ssh
        DRY_RUN=0
        VERBOSE=0
        LOG_FILE=/dev/null
        FAILURES=()
        GIT_EMAIL=mock@example
        ask_reconfigure() { return 1; }
        _ssh_tty_path() { printf "%s" "$TTY_FILE"; }
        configure_ssh
    ' 2>&1) \
    && ! grep -Fq 'Identity added:' <<<"$ssh_add_tty_output" \
    && grep -Fqx 'askpass= require=never' "$ssh_add_marker" \
    && grep -Fqx "fd0=$ssh_add_tty" "$ssh_add_marker" \
    && grep -Fqx "fd1=$ssh_add_tty" "$ssh_add_marker" \
    && grep -Fqx "fd2=$ssh_add_tty" "$ssh_add_marker"; then
    ok 'ssh-add usa terminal dedicado e neutraliza askpass'
else
    error 'ssh-add não isolou a passphrase no terminal'
    ((failures += 1))
fi

tty_file="$ssh_test_home/ssh-keygen.tty"
keygen_marker="$ssh_test_home/ssh-keygen.marker"
: >"$tty_file"
cat >"$fake_bin/ssh-keygen" <<'EOF'
#!/usr/bin/env bash
set -Eeuo pipefail
printf 'askpass=%s require=%s\n' "${SSH_ASKPASS-unset}" "${SSH_ASKPASS_REQUIRE-unset}" >>"$SSH_KEYGEN_MARKER"
for fd in 0 1 2; do
    printf 'fd%s=' "$fd" >>"$SSH_KEYGEN_MARKER"
    readlink "/proc/self/fd/$fd" >>"$SSH_KEYGEN_MARKER"
done
private=''
while (($#)); do
    case $1 in
        -f) private=$2; shift 2 ;;
        *) shift ;;
    esac
done
[[ -n $private ]]
if [[ ${SSH_KEYGEN_MODE:-success} == fail ]]; then
    printf 'partial private\n' >"$private"
    printf 'partial public\n' >"$private.pub"
    exit 1
fi
printf 'generated private\n' >"$private"
printf 'ssh-ed25519 AAAAGENERATED mock@example\n' >"$private.pub"
EOF
chmod +x "$fake_bin/ssh-keygen"

ssh_keygen_case() {
    local mode=$1 home='' output=''
    home="$ssh_test_home/keygen-$mode"
    mkdir -p "$home/.ssh"
    printf 'original private\n' >"$home/.ssh/id_ed25519"
    printf 'ssh-ed25519 AAAAORIGINAL mock@example\n' >"$home/.ssh/id_ed25519.pub"
    chmod 700 "$home/.ssh"
    chmod 600 "$home/.ssh/id_ed25519"
    chmod 644 "$home/.ssh/id_ed25519.pub"
    : >"$keygen_marker"

    output=$(HOME="$home" PATH="$fake_bin:$PATH" SSH_AUTH_SOCK=mock \
        SSH_KEYGEN_MODE="$mode" SSH_KEYGEN_MARKER="$keygen_marker" TTY_FILE="$tty_file" \
        bash -c '
            set -Eeuo pipefail
            source lib/log
            source lib/ask
            source lib/env
            source lib/run
            source lib/ssh
            DRY_RUN=0
            VERBOSE=0
            LOG_FILE=/dev/null
            FAILURES=()
            GIT_EMAIL=mock@example
            ask_reconfigure() { return 0; }
            _ssh_tty_path() { printf "%s" "$TTY_FILE"; }
            if [[ $1 == fail ]]; then
                if configure_ssh; then exit 1; fi
            else
                configure_ssh
            fi
        ' _ "$mode" 2>&1)

    if [[ $mode == fail ]]; then
        [[ $(<"$home/.ssh/id_ed25519") == 'original private' ]]
        [[ $(<"$home/.ssh/id_ed25519.pub") == 'ssh-ed25519 AAAAORIGINAL mock@example' ]]
        [[ $output != *ssh_askpass* ]]
    else
        [[ $(<"$home/.ssh/id_ed25519") == 'generated private' ]]
        [[ $(<"$home/.ssh/id_ed25519.pub") == 'ssh-ed25519 AAAAGENERATED mock@example' ]]
        grep -Fqx "askpass= require=never" "$keygen_marker"
        grep -Fqx "fd0=$tty_file" "$keygen_marker"
        grep -Fqx "fd1=$tty_file" "$keygen_marker"
        grep -Fqx "fd2=$tty_file" "$keygen_marker"
        [[ $output != *ssh_askpass* ]]
    fi
}

if ssh_keygen_case success >/dev/null 2>&1 \
    && ssh_keygen_case fail >/dev/null 2>&1; then
    ok 'ssh-keygen usa terminal dedicado e restaura chave após falha parcial'
else
    error 'ssh-keygen não isolou o terminal ou não restaurou a chave anterior'
    ((failures += 1))
fi

no_tty_home="$ssh_test_home/keygen-no-tty"
no_tty_marker="$ssh_test_home/keygen-no-tty.marker"
mkdir -p "$no_tty_home/.ssh"
printf 'original private\n' >"$no_tty_home/.ssh/id_ed25519"
printf 'ssh-ed25519 AAAAORIGINAL mock@example\n' >"$no_tty_home/.ssh/id_ed25519.pub"
chmod 700 "$no_tty_home/.ssh"
chmod 600 "$no_tty_home/.ssh/id_ed25519"
chmod 644 "$no_tty_home/.ssh/id_ed25519.pub"
: >"$no_tty_marker"
if no_tty_output=$(HOME="$no_tty_home" PATH="$fake_bin:$PATH" SSH_AUTH_SOCK=mock \
    SSH_KEYGEN_MARKER="$no_tty_marker" TTY_FILE="$ssh_test_home/tty-missing" \
    bash -c '
        set -Eeuo pipefail
        source lib/log
        source lib/ask
        source lib/env
        source lib/run
        source lib/ssh
        DRY_RUN=0
        VERBOSE=0
        LOG_FILE=/dev/null
        FAILURES=()
        GIT_EMAIL=mock@example
        ask_reconfigure() { return 0; }
        _ssh_tty_path() { printf "%s" "$TTY_FILE"; }
        if configure_ssh; then exit 1; fi
        [[ $(<"$HOME/.ssh/id_ed25519") == "original private" ]]
        [[ $(<"$HOME/.ssh/id_ed25519.pub") == "ssh-ed25519 AAAAORIGINAL mock@example" ]]
        ! compgen -G "$HOME/.ssh/id_ed25519.bak.*" >/dev/null
    ' 2>&1) \
    && [[ ! -s $no_tty_marker ]] \
    && grep -Fq 'não há terminal disponível para gerar chave SSH interativa' <<<"$no_tty_output"; then
    ok 'sem TTY a geração SSH falha sem mover ou criar chave parcial'
else
    error 'sem TTY a geração SSH alterou a chave existente ou tentou ssh-keygen'
    ((failures += 1))
fi

# A expressão precisa permanecer literal para validar os redirecionamentos.
# shellcheck disable=SC2016
if grep -Fq 'SSH_ASKPASS_REQUIRE=never' lib/ssh \
    && grep -Fq 'exec {fd}<>"$tty"' lib/ssh \
    && grep -Fq '<&"$fd" >&"$fd" 2>&"$fd"' lib/ssh; then
    ok 'geração SSH redireciona descritores para o terminal e neutraliza askpass'
else
    error 'geração SSH não isola ssh-keygen do stdin do pipe'
    ((failures += 1))
fi

if HOME="$ssh_test_home" bash -c '
    set -Eeuo pipefail
    source lib/log
    source lib/ssh
    DRY_RUN=0
    private=$HOME/.ssh/id_ed25519
    public=$private.pub
    _backup_ssh_key "$private" "$public"
    [[ ! -e $private && ! -e $public ]]
    compgen -G "$private.bak.*" >/dev/null
    compgen -G "$public.bak.*" >/dev/null
' >/dev/null 2>&1; then
    ok 'regeneração SSH preserva backups antes de substituir a chave'
else
    error 'backup de chave SSH não foi criado antes da regeneração'
    ((failures += 1))
fi

if HOME="$ssh_test_home" bash -c '
    set -Eeuo pipefail
    source lib/log
    source lib/ssh
    private=$HOME/.ssh/restore-test
    public=$private.pub
    printf private >"$private"
    printf public >"$public"
    _backup_ssh_key "$private" "$public"
    printf partial-private >"$private"
    printf partial-public >"$public"
    _restore_ssh_backup "$private" "$public"
    [[ $(<"$private") == private ]]
    [[ $(<"$public") == public ]]
' >/dev/null 2>&1; then
    ok 'falha de geração SSH pode restaurar a chave anterior'
else
    error 'restauração de backup SSH falhou'
    ((failures += 1))
fi

github_api_backend_test() {
    HOME="$ssh_test_home" GH_API_MARKER="$ssh_test_home/github-api.marker" bash -c '
        set -Eeuo pipefail
        source lib/log
        source lib/env
        source lib/run
        source lib/gh
        LOG_FILE=/dev/null
        DRY_RUN=0
        VERBOSE=0
        mkdir -p "$HOME/.ssh"
        public_key="$HOME/.ssh/id_ed25519.pub"
        printf "ssh-ed25519 AAAACURRENT local@example\\n" >"$public_key"
        GH_API_CURRENT="$HOME/.ssh/current-remote-key"
        GH_API_OLD="$HOME/.ssh/old-remote-key"
        : >"$GH_API_CURRENT"
        : >"$GH_API_OLD"
        : >"$GH_API_MARKER"
        command_exists() { [[ $1 == gh ]]; }
        gh() {
            case "${1:-}:${2:-}:${3:-}:${4:-}" in
                "auth:status::") return 0 ;;
                "api:--silent:user/keys:") return 0 ;;
                "api:--paginate:user/keys:--jq")
                    printf "list\\n" >>"$GH_API_MARKER"
                    if [[ -s $GH_API_CURRENT ]]; then
                        printf "1\\t%s\\t%s\\n" \
                            "$(printf current | base64 -w0)" \
                            "$(base64 -w0 <"$GH_API_CURRENT")"
                    fi
                    if [[ -s $GH_API_OLD ]]; then
                        printf "2\\t%s\\t%s\\n" \
                            "$(printf old | base64 -w0)" \
                            "$(base64 -w0 <"$GH_API_OLD")"
                    fi
                    ;;
                "api:-X:POST:user/keys")
                    for arg in "$@"; do
                        [[ $arg == key=* ]] && printf "%s" "${arg#key=}" >"$GH_API_CURRENT"
                    done
                    [[ $(<"$GH_API_CURRENT") == "ssh-ed25519 AAAACURRENT local@example" ]]
                    printf "post\\n" >>"$GH_API_MARKER"
                    ;;
                "api:-X:DELETE:user/keys/2")
                    : >"$GH_API_OLD"
                    printf "delete:2\\n" >>"$GH_API_MARKER"
                    ;;
                *) return 90 ;;
            esac
        }
        [[ $(github_detect_state) == gh_key_api_available ]]
        github_add_ssh_key "$public_key" "leanin-test"
        [[ $GITHUB_NEW_KEY_STATUS == "cadastrada automaticamente" ]]
        github_key_exists "$public_key"
        printf "ssh-ed25519 AAAAOLD old@example" >"$GH_API_OLD"
        github_list_ssh_keys
        github_collect_old_ssh_keys "$public_key"
        [[ ${#GITHUB_OLD_KEY_IDS[@]} == 1 && ${GITHUB_OLD_KEY_IDS[0]} == 2 ]]
        yesno() { return 0; }
        github_delete_ssh_keys
        grep -Fqx post "$GH_API_MARKER"
        grep -Fqx delete:2 "$GH_API_MARKER"
        [[ $(grep -Fc list "$GH_API_MARKER") -ge 2 ]]
    '
}

if github_api_backend_test >/dev/null 2>&1 \
    && grep -Fq 'gh api --paginate user/keys' lib/gh \
    && grep -Fq 'gh api -X POST user/keys' lib/gh \
    && grep -Fq 'gh api -X DELETE "user/keys/$id"' lib/gh \
    && grep -Fq '_github_key_material' lib/gh \
    && ! grep -Fq 'ssh_signing_keys' lib/gh \
    && ! grep -Eq '^[[:space:]]*gh[[:space:]]+ssh-key[[:space:]]+list' lib/gh \
    && grep -Fq 'if github_ssh_registration_ready; then' install.sh \
    && grep -Fq 'test_github_ssh || true' install.sh; then
    ok 'GitHub usa API user/keys, confirma a chave e isola chaves de assinatura'
else
    error 'backend GitHub user/keys não está completo'
    ((failures += 1))
fi

clipboard_mock() {
    local scenario=$1 fake_clipboard="$ssh_test_home/clipboard-$1" output=''
    rm -f "$fake_clipboard"
    if [[ $scenario != none ]]; then
        cat >"$fake_bin/wl-copy" <<EOF
#!/usr/bin/env bash
cat >/dev/null
[[ $scenario == success ]]
EOF
        chmod +x "$fake_bin/wl-copy"
    else
        rm -f "$fake_bin/wl-copy"
    fi
    output=$(HOME="$ssh_test_home" PATH="$fake_bin:$PATH" SCENARIO="$scenario" bash -c '
        set -Eeuo pipefail
        source lib/log
        source lib/ssh
        DRY_RUN=0
        LOG_FILE=/dev/null
        SSH_PUBLIC_KEY="$HOME/.ssh/clipboard.pub"
        mkdir -p "$HOME/.ssh"
        printf "ssh-ed25519 AAAACLIP mock@example\\n" >"$SSH_PUBLIC_KEY"
        if [[ $SCENARIO == none ]]; then
            command_exists() { return 1; }
        else
            command_exists() { [[ $1 == wl-copy ]]; }
        fi
        print_pubkey
    ' 2>&1) || return 1
    case $scenario in
        success)
            grep -Fq '[ok] chave pública copiada para o clipboard' <<<"$output"
            ;;
        none|failure)
            grep -Fq '[info] clipboard indisponível; copie a chave manualmente' <<<"$output" \
                && ! grep -Fq '[ok] chave pública copiada para o clipboard' <<<"$output"
            ;;
    esac
}

if clipboard_mock none && clipboard_mock failure && clipboard_mock success; then
    ok 'clipboard só confirma cópia quando o comando funciona'
else
    error 'estado do clipboard não reflete o resultado do comando'
    ((failures += 1))
fi

