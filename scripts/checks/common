#!/usr/bin/env bash

ROOT=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/../.." && pwd)
cd "$ROOT" || exit

ok()    { printf '> [ok] %s\n' "$*"; }
skip()  { printf '> [skip] %s\n' "$*"; }
error() { printf '> [error] %s\n' "$*" >&2; }
step()  { printf '\n> Etapa %s/%s: %s\n' "$1" "$2" "$3"; }

failures=0
ssh_test_home=$(mktemp -d)
trap 'rm -rf -- "$ssh_test_home"' EXIT
# Shared array populated by scripts/checks/bash-syntax and consumed by scripts/checks/shellcheck.
# shellcheck disable=SC2034
declare -ag bash_files=()

fixture_path() {
    printf '%s/%s\n' "$ssh_test_home" "$1"
}

fixture_dir() {
    local path
    path=$(fixture_path "$1")
    mkdir -p "$path"
    printf '%s\n' "$path"
}

write_fake_command() {
    local command_path=$1
    mkdir -p "$(dirname -- "$command_path")"
    cat >"$command_path"
    chmod +x "$command_path"
}

seed_ssh_identity() {
    local home=$1
    local private=${2:-original private}
    local public=${3:-ssh-ed25519 AAAAORIGINAL mock@example}

    mkdir -p "$home/.ssh"
    printf '%s\n' "$private" >"$home/.ssh/id_ed25519"
    printf '%s\n' "$public" >"$home/.ssh/id_ed25519.pub"
    chmod 700 "$home/.ssh"
    chmod 600 "$home/.ssh/id_ed25519"
    chmod 644 "$home/.ssh/id_ed25519.pub"
}

check_file() {
    if [[ ! -f $1 ]]; then
        error "arquivo ausente: $1"
        ((failures += 1))
    elif [[ ! -s $1 ]]; then
        error "arquivo obrigatório vazio: $1"
        ((failures += 1))
    else
        ok "$1"
    fi
}

app_lines() {
    local file=$1 line
    while IFS= read -r line || [[ -n $line ]]; do
        line=${line#"${line%%[![:space:]]*}"}
        [[ -z $line || $line == \#* ]] && continue
        line=${line%%[[:space:]]#*}
        line=${line%"${line##*[![:space:]]}"}
        [[ -n $line ]] && printf '%s\n' "$line"
    done <"$file"
}
