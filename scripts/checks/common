#!/usr/bin/env bash

ROOT=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/../.." && pwd)
cd "$ROOT" || exit

ok()    { printf '> [ok] %s\n' "$*"; }
skip()  { printf '> [skip] %s\n' "$*"; }
error() { printf '> [error] %s\n' "$*" >&2; }
step()  { printf '\n> Etapa %s/%s: %s\n' "$1" "$2" "$3"; }

failures=0
ssh_test_home=$(mktemp -d)
trap 'rm -rf -- "$ssh_test_home"' EXIT
# Shared array populated by scripts/checks/bash-syntax and consumed by scripts/checks/shellcheck.
# shellcheck disable=SC2034
declare -ag bash_files=()

check_file() {
    if [[ ! -f $1 ]]; then
        error "arquivo ausente: $1"
        ((failures += 1))
    elif [[ ! -s $1 ]]; then
        error "arquivo obrigatório vazio: $1"
        ((failures += 1))
    else
        ok "$1"
    fi
}

app_lines() {
    local file=$1 line
    while IFS= read -r line || [[ -n $line ]]; do
        line=${line#"${line%%[![:space:]]*}"}
        [[ -z $line || $line == \#* ]] && continue
        line=${line%%[[:space:]]#*}
        line=${line%"${line##*[![:space:]]}"}
        [[ -n $line ]] && printf '%s\n' "$line"
    done <"$file"
}
